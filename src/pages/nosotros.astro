---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Nosotros | Loom" currentPage="nosotros">

  <!-- HERO -->
  <section class="brut-grid-bg" style="background:#f1f1f1; padding:100px 24px 80px; border-bottom:4px solid #0063DA;">
    <div style="max-width:1280px; margin:0 auto; display:grid; grid-template-columns:1fr; gap:48px; align-items:center;" class="hero-grid">
      <style>.hero-grid{grid-template-columns:1fr!important} @media(min-width:768px){.hero-grid{grid-template-columns:1fr 1fr!important}}</style>

      <!-- Text -->
      <div class="brut-reveal">
        <span style="font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; color:#0063DA; display:block; margin-bottom:20px;">// Sobre nosotros</span>
        <h1 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(44px,6vw,80px); font-weight:900; text-transform:uppercase; line-height:0.95; color:#111111; margin-bottom:24px;">
          IMPULSAMOS EL CRECIMIENTO<br/><span style="color:#0063DA;">DE TU MARCA</span>
        </h1>
        <p style="font-family:'Barlow',sans-serif; font-size:17px; color:#555555; line-height:1.65; max-width:480px; margin-bottom:36px;">
          Nos apasiona el tejer estrategias digitales únicas que conecten marcas y audiencias a través de creatividad, basado en data e innovación, creando resultados medibles que impacten positivamente en tu negocio.
        </p>
        <div style="display:flex; gap:16px; flex-wrap:wrap;">
          <button class="brut-btn">Nuestra Historia</button>
          <a href="/#servicios" class="brut-btn">Ver Servicios</a>
        </div>
      </div>

      <!-- Image -->
      <div class="brut-reveal brut-reveal-delay-2" style="position:relative;">
        <div style="position:absolute; top:-8px; left:-8px; right:8px; bottom:8px; border:2px solid #0063DA; z-index:0;"></div>
        <img
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuCQhPEMMIcG4hW_a1hwRUCZbB6U011aYxBNG6rY_Wlm0kLNNxgNBuaZQK2W43MWAdxsIFeJYhACgabnvUUnSsyWL0-nrqiRYX2Ui3MSA7xgEzpBZHaT4sd-QmisarvyAZlU2UxGFMFBb0PDkw8MM7YodinZHkhpF331gfHKMEFT9A2srJO4QsyiX8AnamTwk_Nosqrz92z1UgUOYnS-ROZWMOxxq6yoWgqVdA6u-bhcgrsZ9lnBT24GjhIJG-iVejSSjbOq7wFHksbI"
          alt="Equipo trabajando"
          style="width:100%; position:relative; z-index:1; border:2px solid #0063DA; display:block;"
        />
      </div>

    </div>
  </section>

  <!-- STATS -->
  <section style="background:#f1f1f1; padding:0;">
    <div style="max-width:1280px; margin:0 auto; display:grid; grid-template-columns:repeat(4, 1fr);" class="stats-grid">
      <style>.stats-grid{grid-template-columns:repeat(2,1fr)!important} @media(min-width:768px){.stats-grid{grid-template-columns:repeat(4,1fr)!important}}</style>
      {[
        { num:'500+', label:'Proyectos' },
        { num:'98%',  label:'Retención' },
        { num:'24/7', label:'Soporte' },
        { num:'15',   label:'Países' },
      ].map((s, i) => (
        <div class="brut-reveal" style={`padding:48px 32px; text-align:center; border-right:${i<3 ? '2px solid #0063DA' : 'none'};`}>
          <div style="font-family:'Barlow Condensed',sans-serif; font-size:56px; font-weight:900; color:#0063DA; line-height:1; margin-bottom:8px;">{s.num}</div>
          <div style="font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#555555;">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- QUIÉNES SOMOS -->
  <section style="background:#f1f1f1; padding:80px 24px;">
    <div style="max-width:1280px; margin:0 auto; display:grid; gap:64px; align-items:start;" class="about-grid">
      <style>.about-grid{grid-template-columns:1fr!important} @media(min-width:768px){.about-grid{grid-template-columns:5fr 7fr!important}}</style>

      <!-- Image + badge -->
      <div class="brut-reveal" style="position:relative;">
        <img
          src="/img/loom.jpeg"
          alt="Liderazgo"
          style="width:100%; border:2px solid #0063DA; display:block;"
        />
        <div style="position:absolute; bottom:-20px; right:-20px; background:#0063DA; border:2px solid #0063DA; box-shadow:4px 4px 0 #111111; padding:24px; max-width:220px;">
          <div style="font-family:'Barlow Condensed',sans-serif; font-size:48px; font-weight:900; color:#f1f1f1; line-height:1;">10+</div>
          <div style="font-family:'Barlow',sans-serif; font-size:14px; color:#f1f1f1; line-height:1.4;">Años transformando marcas digitales</div>
        </div>
      </div>

      <!-- Text -->
      <div class="brut-reveal brut-reveal-delay-2">
        <span class="brut-section-label" style="margin-bottom:16px;">[01] / Nuestra esencia</span>
        <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(32px,4vw,48px); font-weight:900; text-transform:uppercase; color:#111111; margin-bottom:24px;">
          Somos el telar digital que<br/><span style="color:#0063DA;">convierte ideas en resultados</span>
        </h2>
        <div style="border-left:4px solid #0063DA; padding-left:24px; margin-bottom:32px;">
          <p style="font-family:'Barlow',sans-serif; font-size:17px; color:#555555; line-height:1.65;">
            Loom significa telar en inglés. El telar simboliza la capacidad de unir hilos diferentes (estrategia, tecnología, diseño, datos) para crear una tela única = una experiencia digital integrada con impacto positivo en tu negocio.
          </p>
        </div>
        <p style="font-family:'Barlow',sans-serif; font-size:16px; color:#555555; line-height:1.65; margin-bottom:36px;">
          Estamos convencidos que cada marca o negocio tiene una historia única por contar, un hilo que, cuando se teje con creatividad, tecnología e innovación, puede convertirse en una experiencia inolvidable, nosotros te ayudamos a hacerlo realidad.
        </p>
        <a href="/contacto" class="brut-btn">Hablemos de tu proyecto →</a>
      </div>

    </div>
  </section>

  <!-- EQUIPO -->
  <section style="background:#f1f1f1; padding:80px 24px;">
    <div style="max-width:1280px; margin:0 auto;">

      <div style="display:flex; justify-content:space-between; align-items:flex-end; padding-bottom:24px; border-bottom:2px solid #0063DA; margin-bottom:24px; flex-wrap:wrap; gap:24px;">
        <div>
          <span class="brut-section-label" style="margin-bottom:8px;">[02] / El equipo</span>
          <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(32px,4vw,48px); font-weight:900; text-transform:uppercase; color:#111111;">
            Nuestro Equipo<br/><span style="color:#0063DA;"> de Innovadores</span>
          </h2>
        </div>
        <a href="/contacto" class="brut-btn">Agenda una cita →</a>
      </div>
      <p style="font-family:'Barlow',sans-serif; font-size:16px; color:#555555; line-height:1.65; margin-bottom:36px;">
        En Loom trabajamos como un telar colectivo, donde cada colaborador, cliente y socio aporta un hilo indispensable. Nuestro equipo está formado por innovadores apasionados siempre en la búsqueda de nuevas estrategias y tecnologías que mantendrán a tu negocio por delante de la competencia.
      </p>

      <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(240px, 1fr)); gap:16px; background:#f1f1f1;">
        {[
          { name:'Alex Rivera', role:'Director Creativo' },
          { name:'Elena Gómez', role:'Estratega SEO' },
          { name:'Marc Costa',  role:'Lead Developer' },
          { name:'Sofía Méndez',role:'Growth Manager' },
        ].map(m => (
          <div class="brut-reveal" style="background:#f1f1f1; border:2px solid #0063DA; box-shadow:4px 4px 0 #0063DA; overflow:hidden; position:relative; cursor:pointer;"
            onmouseover="this.querySelector('img').style.filter='contrast(1.05) saturate(0.85) grayscale(0%)'"
            onmouseout="this.querySelector('img').style.filter='contrast(1.05) saturate(0.85) grayscale(100%)'">
            <div style="aspect-ratio:1; overflow:hidden; position:relative;">
              <img
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuCw68RandWuA-Cm66imlHO-2YaWcYkyGI0n__B4_S0gAi0BT9TZlemaiVNzbqp7ZnAtuiNhTc1WWoidxFicwQzbSRsr89x0zScYYenAWvffaK-8hyCxkJ-KrK7evS0H4ppjC-sokzLd51aYZCAND9vZyT2isoWP-HIPjO-l815HFdkD6RFfB7eTk4xHmxIYOaFZs0SzkKD4y3RF-YA_yvjJalYx9w6JeDn5hyQqMJmJZh5tSU-ey2ZltKzF7vgY__uxG8SKks2sRaFI"
                alt={m.name}
                style="width:100%; height:100%; object-fit:cover; filter:contrast(1.05) saturate(0.85) grayscale(100%); transition:filter 250ms ease-out;"
              />
            </div>
            <div style="padding:20px; border-top:2px solid #0063DA;">
              <h3 style="font-family:'Barlow Condensed',sans-serif; font-size:22px; font-weight:700; text-transform:uppercase; color:#111111; margin-bottom:4px;">{m.name}</h3>
              <span style="font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#0063DA;">{m.role}</span>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

</Layout>
