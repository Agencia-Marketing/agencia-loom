---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Agentes de IA | Loom" currentPage="servicios">

  <!-- HERO -->
  <section style="background:#f1f1f1; padding:72px 24px 64px; border-bottom:4px solid #0063DA; border-left:4px solid #0063DA; position:relative; overflow:hidden;">
    <div style="max-width:1280px; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fit, minmax(320px, 1fr)); gap:48px; align-items:center;">

      <div>
        <span class="brut-section-label" style="display:inline-block; background:#0063DA; color:#f1f1f1; padding:4px 12px; border:2px solid #111111; box-shadow:3px 3px 0 #111111; margin-bottom:20px; font-weight:700;">
          [ SERVICIO / 02 ]
        </span>

        <h1 style="font-size:clamp(48px,6vw,84px); line-height:0.92; margin-bottom:20px; text-transform:uppercase; font-weight:900;">
          AGENTES<br/><span style="color:#0063DA;">DE IA</span>
        </h1>

        <p style="font-family:'Barlow',sans-serif; font-size:18px; color:#555555; line-height:1.6; max-width:540px; margin-bottom:32px;">
          Implementamos agentes inteligentes para automatizar tus procesos de atención al cliente y multiplicar tus ventas en piloto automático 24/7.
        </p>

        <div style="display:flex; flex-wrap:wrap; gap:16px; align-items:center;">
          <a href="/contacto" class="brut-btn" style="background:#0063DA; color:#f1f1f1; border-color:#0063DA; box-shadow:4px 4px 0 #111111; font-size:13px; padding:16px 28px;">
            COTIZAR AGENTE →
          </a>
          <a href="#planes" class="brut-btn" style="font-size:13px; padding:16px 24px;">
            VER PLANES
          </a>
        </div>

        <div style="display:flex; gap:20px; margin-top:32px; border-top:2px solid #0063DA; padding-top:20px; flex-wrap:wrap;">
          <span style="font-family:'JetBrains Mono',monospace; font-size:12px; font-weight:700; color:#111111; display:flex; align-items:center; gap:6px;">
            <span style="color:#0063DA;">✓</span> Atención 24/7
          </span>
          <span style="font-family:'JetBrains Mono',monospace; font-size:12px; font-weight:700; color:#111111; display:flex; align-items:center; gap:6px;">
            <span style="color:#0063DA;">✓</span> Conexión WhatsApp & Web
          </span>
          <span style="font-family:'JetBrains Mono',monospace; font-size:12px; font-weight:700; color:#111111; display:flex; align-items:center; gap:6px;">
            <span style="color:#0063DA;">✓</span> Respuestas Instantáneas
          </span>
        </div>
      </div>

      <div style="position:relative;">
        <div style="border:2px solid #0063DA; background:#ffffff; box-shadow:6px 6px 0 #0063DA; padding:20px; position:relative;">
          <img
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuCLnSXflK2O240IsFhJYQzcgOWK_Zwx4hZdbZ4Q_xkoT3BYT3K73sSBWEMvrj6lXjuZhiOpT_3Nh4ZawOCQeJzkmwo8WB9eMbdyDwXrgv63JLYwkx-dCv9Z6dSuu3O1zTUUZPKGxJEoleqwktDtqUUV9UQMTQSQr-G2QTALFux1cKHWik2cPYhadu13u2beZ0gUp5p7EvRqLAJN20nkRqTJoaV1F_p-sZLi8ntAz-zMUEMk0BZCeGOsLTLF_NH3Pr-JOqp3UvaETxWv"
            alt="Agentes IA"
            style="width:100%; height:auto; display:block; object-fit:contain; max-height:380px;"
          />
        </div>

        <div style="position:absolute; bottom:-16px; left:-16px; background:#111111; color:#f1f1f1; padding:8px 16px; border:2px solid #0063DA; font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; box-shadow:3px 3px 0 #0063DA;">
          🤖 Automatización Inteligente
        </div>
      </div>

    </div>
  </section>

  <!-- FEATURES -->
  <section style="background:#f1f1f1; border-top:4px solid #0063DA;">
    <div style="max-width:1280px; margin:0 auto; display:grid;" class="ia-feat">
      <style>.ia-feat{grid-template-columns:1fr!important} @media(min-width:768px){.ia-feat{grid-template-columns:repeat(3,1fr)!important}}</style>
      {[
        { icon:'schedule',   title:'Disponibilidad 24/7',  desc:'Tu negocio nunca cierra.' },
        { icon:'psychology', title:'IA Avanzada',           desc:'Modelos de última generación.' },
        { icon:'bolt',       title:'Integración Rápida',    desc:'Compatible con WhatsApp, web, Instagram y más.' },
      ].map((f, i) => (
        <div style={`padding:40px 32px; ${i < 2 ? 'border-right:2px solid #0063DA;' : ''}`}>
          <span class="material-symbols-outlined" style="font-size:32px; color:#0063DA; display:block; margin-bottom:16px;">{f.icon}</span>
          <h3 style="font-size:20px; margin-bottom:8px;">{f.title}</h3>
          <p style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#555555; line-height:1.5;">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- PLANES -->
  <section id="planes" style="background:#f1f1f1; padding:80px 24px;">
    <div style="max-width:1280px; margin:0 auto;">
      <span class="brut-section-label" style="margin-bottom:8px;">[02] / Planes</span>
      <h2 style="font-size:clamp(32px,4vw,52px); margin-bottom:48px;">Automatización que <span style="color:#0063DA;">escala contigo</span></h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(300px,1fr)); gap:16px; background:#f1f1f1;">

        <!-- Configuración -->
        <div class="brut-reveal" style="background:#f1f1f1; border:2px solid #0063DA; box-shadow:4px 4px 0 #0063DA; padding:28px; display:flex; flex-direction:column;">
          <h3 style="font-size:22px; margin-bottom:8px;">Configuración Agente 24/7</h3>
          <div style="font-family:'Barlow Condensed',sans-serif; font-size:36px; font-weight:900; color:#0063DA; margin-bottom:20px;">$10,000</div>
          <ul style="list-style:none; padding:0; margin:0 0 24px; flex-grow:1; display:flex; flex-direction:column; gap:8px;">
            <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#555555;"><span style="color:#0063DA; font-weight:bold;">✓</span>Configuración agente IA 24/7 gratis por parte de uno de nuestros ejecutivos.</li>
            <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#555555;"><span style="color:#0063DA; font-weight:bold;">✓</span>Plataforma donde se instala tu agente IA</li>
            <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#555555;"><span style="color:#0063DA; font-weight:bold;">✓</span>Whatsapp API incluido en el precio.</li>
            <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#555555;"><span style="color:#0063DA; font-weight:bold;">✓</span>Soporte técnico por parte de nuestro equipo mes a mes.</li>
            <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#555555;"><span style="color:#0063DA; font-weight:bold;">✓</span>10 MXN de consumo de IA para tus primeros 700 a 800 mensajes.</li>
          </ul>
          <a href="/contacto" class="brut-btn">CONTRATAR →</a>
        </div>

        <!-- Mensualidad -->
        <div class="brut-reveal" style="background:#f1f1f1; border:2px solid #0063DA; box-shadow:4px 4px 0 #0063DA; padding:28px; display:flex; flex-direction:column;">
          <h3 style="font-size:22px; margin-bottom:8px;">Mensualidad Agente 24/7</h3>
          <div style="font-family:'Barlow Condensed',sans-serif; font-size:36px; font-weight:900; color:#0063DA; margin-bottom:20px;">$4,000</div>
          <ul style="list-style:none; padding:0; margin:0 0 24px; flex-grow:1; display:flex; flex-direction:column; gap:8px;">
            <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#555555;"><span style="color:#0063DA; font-weight:bold;">✓</span>Para este servicio se requiere tener una cuenta de HighLead (www.highlead.us) o GHL (www.gohighlevel.com). El pago de la plataforma no está incluido, solo trabajamos con HighLead o GHL. Para otro tipo de embudo o agente de IA, consúltalo antes de hacer el pago.</li>
          </ul>
          <a href="/contacto" class="brut-btn">CONTRATAR →</a>
        </div>

      </div>
    </div>
  </section>

</Layout>
