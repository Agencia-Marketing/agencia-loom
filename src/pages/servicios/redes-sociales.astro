---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Gestión de Redes | Loom" currentPage="servicios">

  <section style="background:#f1f1f1; padding:100px 24px 80px; border-bottom:4px solid #0063DA; position:relative;">
    <div style="position:absolute; top:0; left:0; width:4px; height:100%; background:#0063DA;"></div>
    <div style="max-width:1280px; margin:0 auto;">
      <span style="font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; color:#0063DA; display:block; margin-bottom:16px;">[SERVICIO / 04]</span>
      <h1 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(52px,8vw,100px); font-weight:900; text-transform:uppercase; line-height:0.92; color:#111111; margin-bottom:24px;">
        GESTIÓN DE<br/><span style="color:#0063DA;">REDES SOCIALES</span>
      </h1>
      <p style="font-family:'Barlow',sans-serif; font-size:18px; color:#555555; line-height:1.65; max-width:600px; margin-bottom:48px;">
        Incrementa la interacción con tu audiencia y la notoriedad de tu marca mediante una gestión experta y estratégica de tus redes.
      </p>
      <div style="max-width:900px; border:2px solid #0063DA; box-shadow:6px 6px 0 #0063DA; overflow:hidden;">
        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuCLnSXflK2O240IsFhJYQzcgOWK_Zwx4hZdbZ4Q_xkoT3BYT3K73sSBWEMvrj6lXjuZhiOpT_3Nh4ZawOCQeJzkmwo8WB9eMbdyDwXrgv63JLYwkx-dCv9Z6dSuu3O1zTUUZPKGxJEoleqwktDtqUUV9UQMTQSQr-G2QTALFux1cKHWik2cPYhadu13u2beZ0gUp5p7EvRqLAJN20nkRqTJoaV1F_p-sZLi8ntAz-zMUEMk0BZCeGOsLTLF_NH3Pr-JOqp3UvaETxWv" alt="Redes Sociales" style="width:100%; display:block;" />
      </div>
    </div>
  </section>

  <section style="background:#f1f1f1; border-top:4px solid #0063DA; border-bottom:2px solid #0063DA;">
    <div style="max-width:1280px; margin:0 auto; display:grid;" class="rs-feat">
      <style>.rs-feat{grid-template-columns:1fr!important} @media(min-width:768px){.rs-feat{grid-template-columns:repeat(3,1fr)!important}}</style>
      {[
        { icon:'diversity_3',   title:'Community Mgmt',  desc:'Gestión diaria de comentarios, DMs y engagement con tu comunidad.' },
        { icon:'bar_chart',     title:'Analytics & KPIs', desc:'Reportes detallados de crecimiento, alcance y conversiones.' },
        { icon:'content_paste', title:'Contenido Estratégico', desc:'Calendario editorial alineado con tus objetivos de negocio.' },
      ].map((f, i) => (
        <div style={`padding:40px 32px; ${i < 2 ? 'border-right:2px solid #0063DA;' : ''}`}>
          <span class="material-symbols-outlined" style="font-size:32px; color:#0063DA; display:block; margin-bottom:16px;">{f.icon}</span>
          <h3 style="font-family:'Barlow Condensed',sans-serif; font-size:20px; font-weight:700; text-transform:uppercase; color:#111111; margin-bottom:8px;">{f.title}</h3>
          <p style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#555555; line-height:1.5;">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section style="background:#f1f1f1; padding:80px 24px; border-bottom:2px solid #0063DA;">
    <div style="max-width:1280px; margin:0 auto;">
      <span class="brut-section-label" style="margin-bottom:8px;">[02] / Planes mensuales</span>
      <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(32px,4vw,52px); font-weight:900; text-transform:uppercase; color:#111111; margin-bottom:48px;">
        Gestión profesional <span style="color:#0063DA;">de tus redes</span>
      </h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:2px; background:#0063DA; border:2px solid #0063DA;">
        {[
          { badge:'',            name:'Starter',   price:'$1,200/mes',  features:['1 red social','12 publicaciones/mes','Respuesta a comentarios','Reporte mensual básico'] },
          { badge:'RECOMENDADO', name:'Growth',    price:'$2,400/mes',  features:['3 redes sociales','24 publicaciones/mes','Stories diarias','Analytics avanzado'] },
          { badge:'',            name:'Pro',       price:'$3,600/mes',  features:['5 redes sociales','Post diarios','Paid social incluido','Account manager dedicado'] },
          { badge:'',            name:'Enterprise',price:'A consultar', features:['Redes ilimitadas','Estrategia omnicanal','Equipo dedicado','Acceso 24/7'] },
        ].map(p => (
          <div class="brut-reveal" style={p.badge ? 'background:#0063DA; position:relative;' : 'background:#f1f1f1; position:relative;'}>
            {p.badge && <div style="position:absolute; top:0; left:0; right:0; background:#0063DA; padding:6px; text-align:center;">
              <span style="font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:700; text-transform:uppercase; color:#fff;">{p.badge}</span>
            </div>}
            <div style={`padding:${p.badge ? '52px 28px 28px' : '28px'}; height:100%; display:flex; flex-direction:column;`}>
              <h3 style={`font-family:'Barlow Condensed',sans-serif; font-size:24px; font-weight:900; text-transform:uppercase; margin-bottom:8px; color:${p.badge ? '#f1f1f1' : '#111111'};`}>{p.name}</h3>
              <div style={`font-family:'Barlow Condensed',sans-serif; font-size:28px; font-weight:900; margin-bottom:24px; color:${p.badge ? '#f1f1f1' : '#0063DA'};`}>{p.price}</div>
              <ul style="list-style:none; padding:0; margin:0 0 28px; flex-grow:1; display:flex; flex-direction:column; gap:10px;">
                {p.features.map(f => (
                  <li style={`display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:${p.badge ? '#f1f1f1' : '#555555'};`}>
                    <span style={`color:${p.badge ? '#f1f1f1' : '#0063DA'}; flex-shrink:0;`}>✓</span>{f}
                  </li>
                ))}
              </ul>
              <a href="/contacto" class={p.badge ? 'brut-btn-dark brut-btn' : 'brut-btn'} style="justify-content:center;">CONTRATAR →</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
