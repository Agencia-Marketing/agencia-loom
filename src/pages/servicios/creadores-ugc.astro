---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Creadores UGC | Plantilla 2" currentPage="servicios">

  <section style="background:#0A0A0A; padding:100px 24px 80px; border-bottom:4px solid #AAFF00; position:relative;">
    <div style="position:absolute; top:0; left:0; width:4px; height:100%; background:#AAFF00;"></div>
    <div style="max-width:1280px; margin:0 auto;">
      <span style="font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; color:#AAFF00; display:block; margin-bottom:16px;">[SERVICIO / 08]</span>
      <h1 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(52px,8vw,100px); font-weight:900; text-transform:uppercase; line-height:0.92; color:#F0F0F0; margin-bottom:24px;">
        CREADORES<br/><span style="color:#AAFF00;">UGC</span>
      </h1>
      <p style="font-family:'Barlow',sans-serif; font-size:18px; color:#888; line-height:1.65; max-width:600px; margin-bottom:48px;">
        Humaniza tu marca e impulsa tus ventas con contenido auténtico creado por usuarios reales. El "boca a boca" adaptado a la era digital.
      </p>
      <div style="max-width:900px; border:2px solid #3D3D3D; box-shadow:6px 6px 0 #AAFF00; overflow:hidden;">
        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuBXRqlRBnXPOUpmhBcGowWVCIMgnbmqS7eJ6MzFyQAuiIYe8AOYDMStUoukmUWCN8MRIfaIi1YOYZdd2_LhaAMOj5UqRR4dKJO86QYWJXRSTe1NV6wOZbSRPE9tnSqH6ykR0pqLMTT11U84pt_v_Bg5HQ1mMP0_2cWDTt6BftIERQpvTFtlzXT7o8gWOtQ0tXnDN-QGOEpC1sm80OeaMfYxW0Tu4blx94ljKHKIouQLTRxQ17RjDopYeYc1rKAHXocX_x9mJdUFhIeU" alt="Creadores UGC" style="width:100%; display:block;" />
      </div>
    </div>
  </section>

  <section style="background:#191919; border-top:4px solid #AAFF00; border-bottom:2px solid #2A2A2A;">
    <div style="max-width:1280px; margin:0 auto; display:grid;" class="ugc-feat">
      <style>.ugc-feat{grid-template-columns:1fr!important} @media(min-width:768px){.ugc-feat{grid-template-columns:repeat(3,1fr)!important}}</style>
      {[
        { icon:'record_voice_over', title:'Creadores Verificados', desc:'+3,500 creadores UGC listos en múltiples nichos.' },
        { icon:'thumb_up',          title:'Confianza Auténtica',  desc:'El 94% de usuarios confía más en UGC que en ads tradicionales.' },
        { icon:'rocket_launch',     title:'CTR x3',               desc:'Triple de clics comparado con publicidad convencional.' },
      ].map((f, i) => (
        <div style={`padding:40px 32px; ${i < 2 ? 'border-right:2px solid #2A2A2A;' : ''}`}>
          <span class="material-symbols-outlined" style="font-size:32px; color:#AAFF00; display:block; margin-bottom:16px;">{f.icon}</span>
          <h3 style="font-family:'Barlow Condensed',sans-serif; font-size:20px; font-weight:700; text-transform:uppercase; color:#F0F0F0; margin-bottom:8px;">{f.title}</h3>
          <p style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#888; line-height:1.5;">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Bento + Pricing -->
  <section style="background:#111111; padding:80px 24px; border-bottom:2px solid #2A2A2A;">
    <div style="max-width:1280px; margin:0 auto; display:grid; gap:2px; background:#2A2A2A; border:2px solid #2A2A2A;" class="ugc-layout">
      <style>.ugc-layout{grid-template-columns:1fr!important} @media(min-width:768px){.ugc-layout{grid-template-columns:5fr 7fr!important}}</style>

      <!-- Pricing card -->
      <div class="brut-reveal" style="background:#0A0A0A; padding:48px; border-right:2px solid #2A2A2A;">
        <span class="brut-section-label" style="margin-bottom:16px;">[02] / Plan Pro</span>
        <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:36px; font-weight:900; text-transform:uppercase; color:#AAFF00; margin-bottom:8px; line-height:1.0;">
          El poder del contenido auténtico
        </h2>
        <p style="font-family:'Barlow',sans-serif; font-size:15px; color:#888; line-height:1.6; margin-bottom:24px;">
          Las personas confían en personas. El UGC rompe la barrera de la desconfianza y conecta genuinamente con tu audiencia.
        </p>
        <div style="background:#111111; border:2px solid #3D3D3D; padding:24px; margin-bottom:28px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px;">
          <div>
            <div style="font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#555; margin-bottom:4px;">Inversión desde</div>
            <div style="font-family:'Barlow Condensed',sans-serif; font-size:48px; font-weight:900; color:#AAFF00; line-height:1;">$2,999</div>
          </div>
          <span class="brut-tag">Plan Pro</span>
        </div>
        <ul style="list-style:none; padding:0; margin:0 0 28px; display:flex; flex-direction:column; gap:12px;">
          {[
            'Diseño de script profesional',
            'Selección de perfil especializado',
            '1 video editado listo para publicar',
            'Propuesta estratégica de contenido',
            '1 Trafficker (30 días de optimización)',
          ].map(f => (
            <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#888;">
              <span style="color:#AAFF00; flex-shrink:0;">✓</span>{f}
            </li>
          ))}
        </ul>
        <a href="/contacto" class="brut-btn-filled brut-btn" style="width:100%; justify-content:center;">CONTRATAR AHORA →</a>
      </div>

      <!-- Bento stats + grid -->
      <div class="brut-reveal brut-reveal-delay-2" style="background:#111111; padding:48px; display:flex; flex-direction:column; gap:24px;">
        <div style="border:2px solid #3D3D3D; padding:24px;">
          <h3 style="font-family:'Barlow Condensed',sans-serif; font-size:24px; font-weight:900; text-transform:uppercase; color:#F0F0F0; margin-bottom:8px;">+3,500 creadores UGC listos</h3>
          <p style="font-family:'Barlow',sans-serif; font-size:15px; color:#888;">Red global de creadores apasionados por tu industria.</p>
        </div>

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:2px; background:#2A2A2A; border:2px solid #2A2A2A; flex-grow:1;">
          <div style="grid-column:1/-1; border:2px solid #3D3D3D; overflow:hidden; min-height:200px; background:#2A2A2A;">
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuBe2einU6nwpj_efl8NizXsNTJZBMcf67PrFXuljRvmianwgusmmt4Lj4beG6LPN3gDX2RRFXAw-xz5gOjkVBF5BctZ7AC-g-fxlGgXHurN7SyKix8MRIkDFaGWDI7JAzYxmU0_QZZnI2LxD2ktjuz2FnjRi6chTkELxNTRm80rqOughliPWAW5-0XKZDM2eNFOAGS_VCjaZ2AWwcDTadDp0UcHpXManZPkNZe3JL9IQkr4M9Jhqp4Rlv_Tcn4WzsVBU3i8xTWCJMcT" alt="Creadores" style="width:100%; height:200px; object-fit:cover; display:block;" />
          </div>
          <div style="background:#191919; padding:32px; display:flex; flex-direction:column; justify-content:flex-end;">
            <span class="material-symbols-outlined" style="font-size:28px; color:#AAFF00; margin-bottom:16px;">trending_up</span>
            <div style="font-family:'Barlow Condensed',sans-serif; font-size:48px; font-weight:900; color:#AAFF00; line-height:1;">94%</div>
            <p style="font-family:'Barlow',sans-serif; font-size:13px; color:#888; margin-top:8px; line-height:1.4;">Mayor confianza vs ads tradicionales</p>
          </div>
          <div style="background:#191919; padding:32px; display:flex; flex-direction:column; justify-content:flex-end; border-left:2px solid #2A2A2A;">
            <span class="material-symbols-outlined" style="font-size:28px; color:#FF3C00; margin-bottom:16px;">rocket_launch</span>
            <div style="font-family:'Barlow Condensed',sans-serif; font-size:48px; font-weight:900; color:#FF3C00; line-height:1;">X3</div>
            <p style="font-family:'Barlow',sans-serif; font-size:13px; color:#888; margin-top:8px; line-height:1.4;">CTR en Meta Ads y TikTok</p>
          </div>
        </div>
      </div>

    </div>
  </section>

</Layout>
