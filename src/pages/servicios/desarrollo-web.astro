---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Desarrollo Web | Loom" currentPage="servicios">

  <!-- HERO -->
  <section style="background:#f1f1f1; padding:72px 24px 64px; border-bottom:4px solid #0063DA; border-left:4px solid #0063DA; position:relative; overflow:hidden;">
    <div style="max-width:1280px; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fit, minmax(320px, 1fr)); gap:48px; align-items:center;">

      <div>
        <span class="brut-section-label" style="display:inline-block; background:#0063DA; color:#f1f1f1; padding:4px 12px; border:2px solid #111111; box-shadow:3px 3px 0 #111111; margin-bottom:20px; font-weight:700;">
          [ SERVICIO / 01 ]
        </span>

        <h1 style="font-size:clamp(48px,6vw,84px); line-height:0.92; margin-bottom:20px; text-transform:uppercase; font-weight:900;">
          DESARROLLO<br/><span style="color:#0063DA;">WEB</span>
        </h1>

        <p style="font-family:'Barlow',sans-serif; font-size:18px; color:#555555; line-height:1.6; max-width:540px; margin-bottom:32px;">
          Construimos plataformas a medida que son ultrarrápidas, adaptables a móviles y optimizadas estratégicamente para convertir visitas en clientes reales.
        </p>

        <div style="display:flex; flex-wrap:wrap; gap:16px; align-items:center;">
          <a href="/contacto" class="brut-btn" style="background:#0063DA; color:#f1f1f1; border-color:#0063DA; box-shadow:4px 4px 0 #111111; font-size:13px; padding:16px 28px;">
            COTIZAR MI PROYECTO →
          </a>
          <a href="#planes" class="brut-btn" style="font-size:13px; padding:16px 24px;">
            VER PLANES
          </a>
        </div>

        <div style="display:flex; gap:20px; margin-top:32px; border-top:2px solid #0063DA; padding-top:20px; flex-wrap:wrap;">
          <span style="font-family:'JetBrains Mono',monospace; font-size:12px; font-weight:700; color:#111111; display:flex; align-items:center; gap:6px;">
            <span style="color:#0063DA;">✓</span> Ultra Rápido
          </span>
          <span style="font-family:'JetBrains Mono',monospace; font-size:12px; font-weight:700; color:#111111; display:flex; align-items:center; gap:6px;">
            <span style="color:#0063DA;">✓</span> SEO Básico Incluido
          </span>
          <span style="font-family:'JetBrains Mono',monospace; font-size:12px; font-weight:700; color:#111111; display:flex; align-items:center; gap:6px;">
            <span style="color:#0063DA;">✓</span> 100% Adaptable
          </span>
        </div>
      </div>

      <div style="position:relative;">
        <div style="border:2px solid #0063DA; background:#ffffff; box-shadow:6px 6px 0 #0063DA; padding:20px; position:relative;">
          <img
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuCLnSXflK2O240IsFhJYQzcgOWK_Zwx4hZdbZ4Q_xkoT3BYT3K73sSBWEMvrj6lXjuZhiOpT_3Nh4ZawOCQeJzkmwo8WB9eMbdyDwXrgv63JLYwkx-dCv9Z6dSuu3O1zTUUZPKGxJEoleqwktDtqUUV9UQMTQSQr-G2QTALFux1cKHWik2cPYhadu13u2beZ0gUp5p7EvRqLAJN20nkRqTJoaV1F_p-sZLi8ntAz-zMUEMk0BZCeGOsLTLF_NH3Pr-JOqp3UvaETxWv"
            alt="Desarrollo Web"
            style="width:100%; height:auto; display:block; object-fit:contain; max-height:380px;"
          />
        </div>

        <div style="position:absolute; bottom:-16px; left:-16px; background:#111111; color:#f1f1f1; padding:8px 16px; border:2px solid #0063DA; font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; box-shadow:3px 3px 0 #0063DA;">
          ⚡ Optimizado para Conversión
        </div>
      </div>

    </div>
  </section>

  <!-- FEATURES -->
  <section style="background:#f1f1f1; border-top:4px solid #0063DA;">
    <div style="max-width:1280px; margin:0 auto; display:grid;" class="dw-feat">
      <style>.dw-feat{grid-template-columns:1fr!important} @media(min-width:768px){.dw-feat{grid-template-columns:repeat(3,1fr)!important}}</style>
      {[
        { icon:'speed',       title:'Alto Rendimiento',  desc:'Webs ultrarrápidas optimizadas para Core Web Vitals.' },
        { icon:'devices',     title:'Responsive Design', desc:'Adaptadas a móvil, tablet y escritorio sin concesiones.' },
        { icon:'trending_up', title:'Conversión Óptima', desc:'Diseñadas para convertir visitantes en clientes.' },
      ].map((f, i) => (
        <div style={`padding:40px 32px; ${i < 2 ? 'border-right:2px solid #0063DA;' : ''}`}>
          <span class="material-symbols-outlined" style="font-size:32px; color:#0063DA; display:block; margin-bottom:16px;">{f.icon}</span>
          <h3 style="font-size:20px; margin-bottom:8px;">{f.title}</h3>
          <p style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#555555; line-height:1.5;">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- PLANES -->
  <section id="planes" style="background:#f1f1f1; padding:80px 24px;">
    <div style="max-width:1280px; margin:0 auto;">
      <span class="brut-section-label" style="margin-bottom:8px;">[02] / Nuestros planes</span>
      <h2 style="font-size:clamp(32px,4vw,52px); margin-bottom:48px;">Elige el plan <span style="color:#0063DA;">ideal para ti</span></h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(240px,1fr)); gap:16px; background:#f1f1f1;">

        <!-- Landing Page -->
        <div class="brut-reveal" style="background:#f1f1f1; border:2px solid #0063DA; box-shadow:4px 4px 0 #0063DA; padding:28px; display:flex; flex-direction:column;">
          <h3 style="font-size:22px; margin-bottom:8px;">Landing Page</h3>
          <div style="font-family:'Barlow Condensed',sans-serif; font-size:24px; font-weight:900; color:#0063DA; margin-bottom:20px;">$9,500 - $12,500</div>
          <ul style="list-style:none; padding:0; margin:0 0 24px; flex-grow:1; display:flex; flex-direction:column; gap:8px;">
            <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#555555;"><span style="color:#0063DA; font-weight:bold;">✓</span>Diseño personalizado</li>
            <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#555555;"><span style="color:#0063DA; font-weight:bold;">✓</span>1 página optimizada</li>
            <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#555555;"><span style="color:#0063DA; font-weight:bold;">✓</span>Hosting</li>
            <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#555555;"><span style="color:#0063DA; font-weight:bold;">✓</span>SSL</li>
          </ul>
          <a href="/contacto" class="brut-btn" style="font-size:12px; padding:12px 20px;">CONTRATAR →</a>
        </div>

        <!-- Web Corporativa (RECOMENDADO) -->
        <div class="brut-reveal" style="background:#0063DA; border:2px solid #0063DA; box-shadow:5px 5px 0 #111111; padding:28px; display:flex; flex-direction:column; position:relative;">
          <div style="position:absolute; top:0; left:0; right:0; background:#111111; padding:6px; text-align:center;">
            <span style="font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:700; text-transform:uppercase; color:#ffffff;">RECOMENDADO</span>
          </div>
          <div style="padding-top:32px; display:flex; flex-direction:column; height:100%;">
            <h3 style="font-size:22px; margin-bottom:8px; color:#f1f1f1;">Web Corporativa</h3>
            <div style="font-family:'Barlow Condensed',sans-serif; font-size:24px; font-weight:900; color:#f1f1f1; margin-bottom:20px;">$13,500 - $16,500</div>
            <ul style="list-style:none; padding:0; margin:0 0 24px; flex-grow:1; display:flex; flex-direction:column; gap:8px;">
              <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#f1f1f1;"><span style="color:#f1f1f1; font-weight:bold;">✓</span>Hasta 5 páginas</li>
              <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#f1f1f1;"><span style="color:#f1f1f1; font-weight:bold;">✓</span>Hosting</li>
              <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#f1f1f1;"><span style="color:#f1f1f1; font-weight:bold;">✓</span>SSL</li>
            </ul>
            <a href="/contacto" class="brut-btn" style="font-size:12px; padding:12px 20px; background:#f1f1f1; color:#0063DA; border-color:#f1f1f1; box-shadow:3px 3px 0 #111111;">CONTRATAR →</a>
          </div>
        </div>

        <!-- E-Commerce WhatsApp -->
        <div class="brut-reveal" style="background:#f1f1f1; border:2px solid #0063DA; box-shadow:4px 4px 0 #0063DA; padding:28px; display:flex; flex-direction:column;">
          <h3 style="font-size:22px; margin-bottom:8px;">E-Commerce WhatsApp</h3>
          <div style="font-family:'Barlow Condensed',sans-serif; font-size:24px; font-weight:900; color:#0063DA; margin-bottom:20px;">$15,500 - $19,500</div>
          <ul style="list-style:none; padding:0; margin:0 0 24px; flex-grow:1; display:flex; flex-direction:column; gap:8px;">
            <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#555555;"><span style="color:#0063DA; font-weight:bold;">✓</span>Catálogo de productos con botón a WhatsApp</li>
            <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#555555;"><span style="color:#0063DA; font-weight:bold;">✓</span>Gestión inventario</li>
            <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#555555;"><span style="color:#0063DA; font-weight:bold;">✓</span>Hosting y SSL</li>
          </ul>
          <a href="/contacto" class="brut-btn" style="font-size:12px; padding:12px 20px;">CONTRATAR →</a>
        </div>

        <!-- E-Commerce -->
        <div class="brut-reveal" style="background:#f1f1f1; border:2px solid #0063DA; box-shadow:4px 4px 0 #0063DA; padding:28px; display:flex; flex-direction:column;">
          <h3 style="font-size:22px; margin-bottom:8px;">E-Commerce</h3>
          <div style="font-family:'Barlow Condensed',sans-serif; font-size:24px; font-weight:900; color:#0063DA; margin-bottom:20px;">$15,500 - $22,500</div>
          <ul style="list-style:none; padding:0; margin:0 0 24px; flex-grow:1; display:flex; flex-direction:column; gap:8px;">
            <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#555555;"><span style="color:#0063DA; font-weight:bold;">✓</span>5 páginas</li>
            <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#555555;"><span style="color:#0063DA; font-weight:bold;">✓</span>Tienda en línea</li>
            <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#555555;"><span style="color:#0063DA; font-weight:bold;">✓</span>Pasarelas de pago</li>
            <li style="display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:#555555;"><span style="color:#0063DA; font-weight:bold;">✓</span>Hosting y SSL</li>
          </ul>
          <a href="/contacto" class="brut-btn" style="font-size:12px; padding:12px 20px;">CONTRATAR →</a>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:#f1f1f1; padding:64px 24px;">
    <div style="max-width:1280px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:24px; border:2px solid #0063DA; padding:48px; box-shadow:5px 5px 0 #0063DA;">
      <div>
        <h2 style="font-size:clamp(28px,4vw,48px); color:#111111; margin-bottom:8px;">¿Listo para lanzar tu proyecto web?</h2>
        <p style="font-family:'Barlow',sans-serif; font-size:16px; color:#555555; margin:0;">Contáctanos y empieza hoy mismo.</p>
      </div>
      <a href="/contacto" class="brut-btn" style="white-space:nowrap;">SOLICITAR PRESUPUESTO →</a>
    </div>
  </section>

</Layout>
