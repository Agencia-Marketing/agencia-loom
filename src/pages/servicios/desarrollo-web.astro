---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Desarrollo Web | Loom" currentPage="servicios">

  <!-- HERO -->
  <section style="background:#f1f1f1; padding:100px 24px 80px; border-bottom:4px solid #0063DA; border-left:0; position:relative; overflow:hidden;">
    <div style="position:absolute; top:0; left:0; width:4px; height:100%; background:#0063DA;"></div>
    <div style="max-width:1280px; margin:0 auto;">
      <span style="font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; color:#0063DA; display:block; margin-bottom:16px;">[SERVICIO / 01]</span>
      <h1 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(52px,8vw,100px); font-weight:900; text-transform:uppercase; line-height:0.92; color:#111111; margin-bottom:24px;">
        DESARROLLO<br/><span style="color:#0063DA;">WEB</span>
      </h1>
      <p style="font-family:'Barlow',sans-serif; font-size:18px; color:#555555; line-height:1.65; max-width:600px; margin-bottom:48px;">
        Construimos plataformas a medida que son rápidas, adaptables y optimizadas para convertir visitas en clientes reales.
      </p>
      <div style="max-width:900px; border:2px solid #0063DA; box-shadow:6px 6px 0 #0063DA; overflow:hidden;">
        <img
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuCLnSXflK2O240IsFhJYQzcgOWK_Zwx4hZdbZ4Q_xkoT3BYT3K73sSBWEMvrj6lXjuZhiOpT_3Nh4ZawOCQeJzkmwo8WB9eMbdyDwXrgv63JLYwkx-dCv9Z6dSuu3O1zTUUZPKGxJEoleqwktDtqUUV9UQMTQSQr-G2QTALFux1cKHWik2cPYhadu13u2beZ0gUp5p7EvRqLAJN20nkRqTJoaV1F_p-sZLi8ntAz-zMUEMk0BZCeGOsLTLF_NH3Pr-JOqp3UvaETxWv"
          alt="Desarrollo Web"
          style="width:100%; display:block;"
        />
      </div>
    </div>
  </section>

  <!-- FEATURES BAR -->
  <section style="background:#f1f1f1; border-bottom:2px solid #0063DA;">
    <div style="max-width:1280px; margin:0 auto; display:grid; grid-template-columns:repeat(3,1fr);" class="feat-grid">
      <style>.feat-grid{grid-template-columns:1fr!important} @media(min-width:768px){.feat-grid{grid-template-columns:repeat(3,1fr)!important}}</style>
      {[
        { icon:'speed',          title:'Alto Rendimiento',   desc:'Webs ultrarrápidas optimizadas para Core Web Vitals.' },
        { icon:'devices',        title:'Responsive Design',  desc:'Adaptadas a móvil, tablet y escritorio sin concesiones.' },
        { icon:'trending_up',    title:'Conversión Óptima',  desc:'Diseñadas para convertir visitantes en clientes.' },
      ].map((f, i) => (
        <div style={`padding:40px 32px; ${i < 2 ? 'border-right:2px solid #0063DA;' : ''}`}>
          <span class="material-symbols-outlined" style="font-size:32px; color:#0063DA; display:block; margin-bottom:16px;">{f.icon}</span>
          <h3 style="font-family:'Barlow Condensed',sans-serif; font-size:20px; font-weight:700; text-transform:uppercase; color:#111111; margin-bottom:8px;">{f.title}</h3>
          <p style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#555555; line-height:1.5;">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- PLANES -->
  <section style="background:#f1f1f1; padding:80px 24px; border-bottom:2px solid #0063DA;">
    <div style="max-width:1280px; margin:0 auto;">
      <div style="padding-bottom:32px; border-bottom:2px solid #0063DA; margin-bottom:48px;">
        <span class="brut-section-label" style="margin-bottom:8px; color:#0063DA;">[02] / Nuestros planes</span>
        <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(32px,4vw,52px); font-weight:900; text-transform:uppercase; color:#111111;">
          Elige el plan que se adapta<br/><span style="color:#0063DA;">a tu proyecto</span>
        </h2>
      </div>

      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:16px; background:#f1f1f1;">
        {[
          { badge:'',            name:'Landing Page',       price:'$9,500 - $12,500', features:['Diseño personalizado','1 página optimizada','Hosting','SSL'] },
          { badge:'RECOMENDADO', name:'Web informativo',    price:'$13,500 - $16,500', features:['Hasta 5 páginas','Hosting','SSL'] },
          { badge:'',            name:'E-commerce WhatsApp', price:'$15,500 - $19,500', features:['Catálogo de productos con botón a WhatsApp','Hosting','SSL'] },
          { badge:'',            name:'E-commerce',          price:'$15,500 - $22,500', features:['Tienda en línea','2 Pasarelas de pago','Hosting','SSL'] },
        ].map((p) => (
          <div class="brut-reveal" style={p.badge ? 'background:#0063DA; border:2px solid #0063DA; box-shadow:5px 5px 0 #111111; position:relative;' : 'background:#f1f1f1; border:2px solid #0063DA; box-shadow:4px 4px 0 #0063DA; position:relative;'}>
            {p.badge && <div style="position:absolute; top:0; left:0; right:0; background:#111111; padding:6px 12px; text-align:center;">
              <span style="font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#0063DA;">{p.badge}</span>
            </div>}
            <div style={`padding:${p.badge ? '56px 28px 28px' : '28px'}; display:flex; flex-direction:column; height:100%;`}>
              <h3 style={`font-family:'Barlow Condensed',sans-serif; font-size:24px; font-weight:900; text-transform:uppercase; margin-bottom:8px; color:${p.badge ? '#f1f1f1' : '#111111'};`}>{p.name}</h3>
              <div style={`font-family:'Barlow Condensed',sans-serif; font-size:28px; font-weight:900; margin-bottom:24px; color:${p.badge ? '#f1f1f1' : '#0063DA'};`}>{p.price}</div>
              <ul style="list-style:none; padding:0; margin:0 0 28px; flex-grow:1; display:flex; flex-direction:column; gap:10px;">
                {p.features.map(f => (
                  <li style={`display:flex; align-items:start; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; line-height:1.4; color:${p.badge ? '#f1f1f1' : '#555555'};`}>
                    <span style={`color:${p.badge ? '#f1f1f1' : '#0063DA'}; font-size:14px; flex-shrink:0; margin-top:1px; font-weight:bold;`}>✓</span>
                    {f}
                  </li>
                ))}
              </ul>
              <a href="/contacto" class="brut-btn" style={`text-align:center; justify-content:center; border-color:${p.badge ? '#f1f1f1' : '#0063DA'}; color:${p.badge ? '#f1f1f1' : '#0063DA'}; box-shadow:3px 3px 0 ${p.badge ? '#111111' : '#0063DA'};`}>
                CONTRATAR →
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:#f1f1f1; padding:64px 24px; border-bottom:2px solid #0063DA;">
    <div style="max-width:1280px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:24px; border:2px solid #0063DA; padding:48px; box-shadow:5px 5px 0 #0063DA;">
      <div>
        <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(28px,4vw,48px); font-weight:900; text-transform:uppercase; color:#111111; margin-bottom:8px;">
          ¿Listo para lanzar tu proyecto web?
        </h2>
        <p style="font-family:'Barlow',sans-serif; font-size:16px; color:#555555;">Contáctanos y empieza hoy mismo.</p>
      </div>
      <a href="/contacto" class="brut-btn" style="white-space:nowrap;">SOLICITAR PRESUPUESTO →</a>
    </div>
  </section>

</Layout>