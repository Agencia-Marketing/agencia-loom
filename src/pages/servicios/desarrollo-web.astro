---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Desarrollo Web | Plantilla 2" currentPage="servicios">

  <!-- HERO -->
  <section style="background:#0A0A0A; padding:100px 24px 80px; border-bottom:4px solid #AAFF00; border-left:0; position:relative; overflow:hidden;">
    <div style="position:absolute; top:0; left:0; width:4px; height:100%; background:#AAFF00;"></div>
    <div style="max-width:1280px; margin:0 auto;">
      <span style="font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; color:#AAFF00; display:block; margin-bottom:16px;">[SERVICIO / 01]</span>
      <h1 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(52px,8vw,100px); font-weight:900; text-transform:uppercase; line-height:0.92; color:#F0F0F0; margin-bottom:24px;">
        DESARROLLO<br/><span style="color:#AAFF00;">WEB</span>
      </h1>
      <p style="font-family:'Barlow',sans-serif; font-size:18px; color:#888; line-height:1.65; max-width:600px; margin-bottom:48px;">
        Construimos plataformas a medida que son rápidas, adaptables y optimizadas para convertir visitas en clientes reales.
      </p>
      <div style="max-width:900px; border:2px solid #3D3D3D; box-shadow:6px 6px 0 #AAFF00; overflow:hidden;">
        <img
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuCLnSXflK2O240IsFhJYQzcgOWK_Zwx4hZdbZ4Q_xkoT3BYT3K73sSBWEMvrj6lXjuZhiOpT_3Nh4ZawOCQeJzkmwo8WB9eMbdyDwXrgv63JLYwkx-dCv9Z6dSuu3O1zTUUZPKGxJEoleqwktDtqUUV9UQMTQSQr-G2QTALFux1cKHWik2cPYhadu13u2beZ0gUp5p7EvRqLAJN20nkRqTJoaV1F_p-sZLi8ntAz-zMUEMk0BZCeGOsLTLF_NH3Pr-JOqp3UvaETxWv"
          alt="Desarrollo Web"
          style="width:100%; display:block;"
        />
      </div>
    </div>
  </section>

  <!-- FEATURES BAR -->
  <section style="background:#191919; border-bottom:2px solid #2A2A2A; border-top:4px solid #AAFF00;">
    <div style="max-width:1280px; margin:0 auto; display:grid; grid-template-columns:repeat(3,1fr);" class="feat-grid">
      <style>.feat-grid{grid-template-columns:1fr!important} @media(min-width:768px){.feat-grid{grid-template-columns:repeat(3,1fr)!important}}</style>
      {[
        { icon:'speed',          title:'Alto Rendimiento',   desc:'Webs ultrarrápidas optimizadas para Core Web Vitals.' },
        { icon:'devices',        title:'Responsive Design',  desc:'Adaptadas a móvil, tablet y escritorio sin concesiones.' },
        { icon:'trending_up',    title:'Conversión Óptima',  desc:'Diseñadas para convertir visitantes en clientes.' },
      ].map((f, i) => (
        <div style={`padding:40px 32px; ${i < 2 ? 'border-right:2px solid #2A2A2A;' : ''}`}>
          <span class="material-symbols-outlined" style="font-size:32px; color:#AAFF00; display:block; margin-bottom:16px;">{f.icon}</span>
          <h3 style="font-family:'Barlow Condensed',sans-serif; font-size:20px; font-weight:700; text-transform:uppercase; color:#F0F0F0; margin-bottom:8px;">{f.title}</h3>
          <p style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#888; line-height:1.5;">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- PLANES -->
  <section style="background:#111111; padding:80px 24px; border-bottom:2px solid #2A2A2A;">
    <div style="max-width:1280px; margin:0 auto;">
      <div style="padding-bottom:32px; border-bottom:2px solid #3D3D3D; margin-bottom:48px;">
        <span class="brut-section-label" style="margin-bottom:8px;">[02] / Nuestros planes</span>
        <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(32px,4vw,52px); font-weight:900; text-transform:uppercase; color:#F0F0F0;">
          Elige el plan que se adapta<br/><span style="color:#AAFF00;">a tu proyecto</span>
        </h2>
      </div>

      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:2px; background:#2A2A2A; border:2px solid #2A2A2A;">
        {[
          { badge:'',            name:'Landing Page',    price:'$13,000 - $17,400', features:['Diseño personalizado','1 página optimizada','SEO básico','Formulario de contacto'] },
          { badge:'RECOMENDADO', name:'Web Corporativa', price:'$14,500 - $20,300', features:['Hasta 5 páginas','Blog integrado','SEO avanzado','Panel de admin'] },
          { badge:'',            name:'E-Commerce',      price:'$17,400 - $26,100', features:['Tienda completa','Pasarela de pago','Gestión de inventario','Reportes de ventas'] },
          { badge:'',            name:'E-Com Avanzado',  price:'$23,200 - $29,900', features:['Multi-idioma','App móvil incluida','API personalizada','Soporte premium 24/7'] },
        ].map((p) => (
          <div class="brut-reveal" style={p.badge ? 'background:#AAFF00; border-right:2px solid #88CC00; box-shadow:none; position:relative;' : 'background:#111111; position:relative;'}>
            {p.badge && <div style="position:absolute; top:0; left:0; right:0; background:#FF3C00; padding:6px 12px; text-align:center;">
              <span style="font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#fff;">{p.badge}</span>
            </div>}
            <div style={`padding:${p.badge ? '56px 28px 28px' : '28px'}; display:flex; flex-direction:column; height:100%;`}>
              <h3 style={`font-family:'Barlow Condensed',sans-serif; font-size:24px; font-weight:900; text-transform:uppercase; margin-bottom:8px; color:${p.badge ? '#0A0A0A' : '#F0F0F0'};`}>{p.name}</h3>
              <div style={`font-family:'Barlow Condensed',sans-serif; font-size:28px; font-weight:900; margin-bottom:24px; color:${p.badge ? '#1A2600' : '#AAFF00'};`}>{p.price}</div>
              <ul style="list-style:none; padding:0; margin:0 0 28px; flex-grow:1; display:flex; flex-direction:column; gap:10px;">
                {p.features.map(f => (
                  <li style={`display:flex; align-items:start; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; line-height:1.4; color:${p.badge ? '#1A2600' : '#888'};`}>
                    <span style={`color:${p.badge ? '#0A0A0A' : '#AAFF00'}; font-size:14px; flex-shrink:0; margin-top:1px;`}>✓</span>
                    {f}
                  </li>
                ))}
              </ul>
              <a href="/contacto" class={p.badge ? 'brut-btn-dark brut-btn' : 'brut-btn'} style="text-align:center; justify-content:center;">
                CONTRATAR →
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background:#AAFF00; padding:64px 24px; border-bottom:2px solid #88CC00;">
    <div style="max-width:1280px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:24px;">
      <div>
        <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(28px,4vw,48px); font-weight:900; text-transform:uppercase; color:#0A0A0A; margin-bottom:8px;">
          ¿Listo para lanzar tu proyecto web?
        </h2>
        <p style="font-family:'Barlow',sans-serif; font-size:16px; color:#1A2600;">Contáctanos y empieza hoy mismo.</p>
      </div>
      <a href="/contacto" class="brut-btn-dark brut-btn" style="white-space:nowrap;">SOLICITAR PRESUPUESTO →</a>
    </div>
  </section>

</Layout>
