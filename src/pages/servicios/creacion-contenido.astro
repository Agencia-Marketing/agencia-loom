---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Creación de Contenido | Loom" currentPage="servicios">

  <section style="background:#f1f1f1; padding:100px 24px 80px; border-bottom:4px solid #0063DA; position:relative;">
    <div style="position:absolute; top:0; left:0; width:4px; height:100%; background:#0063DA;"></div>
    <div style="max-width:1280px; margin:0 auto;">
      <span style="font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; color:#0063DA; display:block; margin-bottom:16px;">[SERVICIO / 09]</span>
      <h1 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(52px,8vw,100px); font-weight:900; text-transform:uppercase; line-height:0.92; color:#111111; margin-bottom:24px;">
        CREACIÓN DE<br/><span style="color:#0063DA;">CONTENIDO</span>
      </h1>
      <p style="font-family:'Barlow',sans-serif; font-size:18px; color:#555555; line-height:1.65; max-width:600px; margin-bottom:48px;">
        Despierta la creatividad de tu negocio con piezas visuales diseñadas para captar la atención de tu audiencia y elevar el valor de tu marca.
      </p>
      <div style="max-width:900px; border:2px solid #0063DA; box-shadow:6px 6px 0 #0063DA; overflow:hidden;">
        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAi3HyL4CFp_FZExC_kzlNCA6qGuLRiIopI9ejP3t1eBTAM7e_CyZmVE5ZEP8csPCh1guMUBMElJ4sSaMhyV_jL23X97tPIFTD9x9pf0lHUHVdmrM_LnhI4FX1Sd3l-MyUOJxnM8m-pB7CjXayOIuYICu5rJhJ34-J2zKKAgAaAUuLd4ruS1dtvwEoTekUs5sbNYQMesIH6rbtUloVB0pt3NaNczMeXy2QPihenaGhLJBD3QBHaIsZhuLcDKvY20RzRaA4I_3PIvFZe" alt="Creación de Contenido" style="width:100%; display:block;" />
      </div>
    </div>
  </section>

  <section style="background:#f1f1f1; border-top:4px solid #0063DA; border-bottom:2px solid #0063DA;">
    <div style="max-width:1280px; margin:0 auto; display:grid;" class="cc-feat">
      <style>.cc-feat{grid-template-columns:1fr!important} @media(min-width:768px){.cc-feat{grid-template-columns:repeat(3,1fr)!important}}</style>
      {[
        { icon:'image',         title:'Diseño Visual',    desc:'Gráficos impactantes en Canva con editables para tu equipo.' },
        { icon:'movie',         title:'Formato Video',    desc:'Hasta el 50% de cada paquete en formato video o Reels.' },
        { icon:'bolt',          title:'Entrega Rápida',   desc:'Piezas listas en 1 a 6 días hábiles según el paquete.' },
      ].map((f, i) => (
        <div style={`padding:40px 32px; ${i < 2 ? 'border-right:2px solid #0063DA;' : ''}`}>
          <span class="material-symbols-outlined" style="font-size:32px; color:#0063DA; display:block; margin-bottom:16px;">{f.icon}</span>
          <h3 style="font-family:'Barlow Condensed',sans-serif; font-size:20px; font-weight:700; text-transform:uppercase; color:#111111; margin-bottom:8px;">{f.title}</h3>
          <p style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#555555; line-height:1.5;">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section style="background:#f1f1f1; padding:80px 24px; border-bottom:2px solid #0063DA;">
    <div style="max-width:1280px; margin:0 auto;">
      <span class="brut-section-label" style="margin-bottom:8px;">[02] / Paquetes de diseño</span>
      <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(32px,4vw,52px); font-weight:900; text-transform:uppercase; color:#111111; margin-bottom:48px;">
        Contenido visual <span style="color:#0063DA;">que convierte</span>
      </h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:2px; background:#0063DA; border:2px solid #0063DA;">
        {[
          { badge:'',            name:'Diseño Individual',   price:'$245',   delivery:'1-2 días', count:'1 diseño (imagen fija)', features:['Editable en CANVA','1 misma línea gráfica','Formato adaptable'] },
          { badge:'RECOMENDADO', name:'Pack 15 Diseños',     price:'$2,200', delivery:'5 días',   count:'15 diseños (hasta 8 en video)', features:['Editables en CANVA','1 línea gráfica','Incluye videos/Reels'] },
          { badge:'',            name:'Pack 20 Diseños',     price:'$2,800', delivery:'5 días',   count:'20 diseños (hasta 10 en video)', features:['Editables en CANVA','1 línea gráfica','Variantes de formato'] },
          { badge:'',            name:'Pack 30 Diseños',     price:'$3,000', delivery:'6 días',   count:'30 diseños (hasta 15 en video)', features:['Editables en CANVA','1 línea gráfica','Pack completo mensual'] },
        ].map(p => (
          <div class="brut-reveal" style={p.badge ? 'background:#0063DA; position:relative;' : 'background:#f1f1f1; position:relative;'}>
            {p.badge && <div style="position:absolute; top:0; left:0; right:0; background:#0063DA; padding:6px; text-align:center;">
              <span style="font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:700; text-transform:uppercase; color:#fff;">{p.badge}</span>
            </div>}
            <div style={`padding:${p.badge ? '52px 24px 24px' : '24px'}; height:100%; display:flex; flex-direction:column;`}>
              <h3 style={`font-family:'Barlow Condensed',sans-serif; font-size:22px; font-weight:900; text-transform:uppercase; margin-bottom:4px; color:${p.badge ? '#f1f1f1' : '#111111'};`}>{p.name}</h3>
              <div style={`font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px; color:${p.badge ? '#f1f1f1' : '#555'};`}>{p.count}</div>
              <div style={`font-family:'Barlow Condensed',sans-serif; font-size:36px; font-weight:900; margin-bottom:4px; color:${p.badge ? '#f1f1f1' : '#0063DA'};`}>{p.price}</div>
              <div style={`font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; color:${p.badge ? '#f1f1f1' : '#555'}; margin-bottom:20px;`}>Entrega: {p.delivery}</div>
              <ul style="list-style:none; padding:0; margin:0 0 24px; flex-grow:1; display:flex; flex-direction:column; gap:8px;">
                {p.features.map(f => (
                  <li style={`display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:13px; color:${p.badge ? '#f1f1f1' : '#555555'};`}>
                    <span style={`color:${p.badge ? '#f1f1f1' : '#0063DA'}; flex-shrink:0;`}>✓</span>{f}
                  </li>
                ))}
              </ul>
              <a href="/contacto" class={p.badge ? 'brut-btn-dark brut-btn' : 'brut-btn'} style="justify-content:center; font-size:12px; padding:12px 20px;">CONTRATAR →</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section style="background:#f1f1f1; padding:64px 24px; border-bottom:2px solid #0063DA;">
    <div style="max-width:1280px; margin:0 auto;">
      <div style="background:#0063DA; border:2px solid #004eb1; box-shadow:6px 6px 0 #004eb1; padding:64px 48px; text-align:center;">
        <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(28px,4vw,48px); font-weight:900; text-transform:uppercase; color:#f1f1f1; margin-bottom:16px;">
          ¿Listo para transformar tu presencia visual?
        </h2>
        <p style="font-family:'Barlow',sans-serif; font-size:17px; color:#f1f1f1; line-height:1.65; max-width:480px; margin:0 auto 36px;">
          Contáctanos y comencemos a diseñar piezas que realmente conecten con tu público objetivo.
        </p>
        <a href="/contacto" class="brut-btn-dark brut-btn" style="margin:0 auto;">HABLAR CON UN EXPERTO →</a>
      </div>
    </div>
  </section>

</Layout>
