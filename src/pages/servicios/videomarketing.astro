---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Videomarketing | Loom" currentPage="servicios">

  <section style="background:#f1f1f1; padding:100px 24px 80px; border-bottom:4px solid #0063DA; position:relative;">
    <div style="position:absolute; top:0; left:0; width:4px; height:100%; background:#0063DA;"></div>
    <div style="max-width:1280px; margin:0 auto;">
      <span style="font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; color:#0063DA; display:block; margin-bottom:16px;">[SERVICIO / 06]</span>
      <h1 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(52px,8vw,100px); font-weight:900; text-transform:uppercase; line-height:0.92; color:#111111; margin-bottom:24px;">
        VIDEO<br/><span style="color:#0063DA;">MARKETING</span>
      </h1>
      <p style="font-family:'Barlow',sans-serif; font-size:18px; color:#555555; line-height:1.65; max-width:600px; margin-bottom:48px;">
        Captura la atención de tu audiencia y multiplica tus conversiones con contenido audiovisual diseñado para destacar y vender en cualquier plataforma.
      </p>
      <div style="max-width:900px; border:2px solid #0063DA; box-shadow:6px 6px 0 #0063DA; overflow:hidden;">
        <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuBFUqr1X_pwtHpAKqWNwAPUSlJ5tT3-T5BKTSC_M6ISDLBXNT8Qn2TXvA5C96UgXUfZWfmKJEBv_P18mnzfeewriiEUJeqGpsW2RQD42EgsMFXzHumLN8B9plFTZK-Tn13ozZTVgeuSreTazqm2zALs6LIaFQhsnPZRkUSifKNYZxrxmBZNEyIJgNBmtmtSJ6khRZEWRWUyd1OKtWPnCTrXH_LcAGdxLAZ-F8gpFolWeiiMFWUwJXSRsbAbEK-qCoq8JEvpTtjdOLqs" alt="Videomarketing" style="width:100%; display:block;" />
      </div>
    </div>
  </section>

  <section style="background:#f1f1f1; border-top:4px solid #0063DA; border-bottom:2px solid #0063DA;">
    <div style="max-width:1280px; margin:0 auto; display:grid;" class="vm-feat">
      <style>.vm-feat{grid-template-columns:1fr!important} @media(min-width:768px){.vm-feat{grid-template-columns:repeat(3,1fr)!important}}</style>
      {[
        { icon:'favorite',    title:'Mayor Retención',  desc:'Conectamos emocionalmente con tu audiencia objetivo.' },
        { icon:'trending_up', title:'Alcance Viral',    desc:'Contenido diseñado para ser compartido en redes.' },
        { icon:'devices',     title:'Multiplataforma',  desc:'Formatos optimizados para YouTube, Reels, TikTok y más.' },
      ].map((f, i) => (
        <div style={`padding:40px 32px; ${i < 2 ? 'border-right:2px solid #0063DA;' : ''}`}>
          <span class="material-symbols-outlined" style="font-size:32px; color:#0063DA; display:block; margin-bottom:16px;">{f.icon}</span>
          <h3 style="font-family:'Barlow Condensed',sans-serif; font-size:20px; font-weight:700; text-transform:uppercase; color:#111111; margin-bottom:8px;">{f.title}</h3>
          <p style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#555555; line-height:1.5;">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section style="background:#f1f1f1; padding:80px 24px; border-bottom:2px solid #0063DA;">
    <div style="max-width:1280px; margin:0 auto;">
      <span class="brut-section-label" style="margin-bottom:8px;">[02] / Planes de producción</span>
      <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(32px,4vw,52px); font-weight:900; text-transform:uppercase; color:#111111; margin-bottom:48px;">
        Producción audiovisual <span style="color:#0063DA;">de alto impacto</span>
      </h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:2px; background:#0063DA; border:2px solid #0063DA;">
        {[
          { badge:'',            name:'Video Básico',      price:'$975 - $2,321',   features:['Edición básica','1 corrección','Formato Horizontal','Entrega en 5 días'] },
          { badge:'RECOMENDADO', name:'Video Intermedio',  price:'$1,950 - $4,641', features:['Edición avanzada','Motion Graphics','Música sin copyright','Formato multi-plataforma'] },
          { badge:'',            name:'Video Completo',    price:'$2,600 - $11,603',features:['Estrategia completa','Guion profesional','Múltiples formatos','Voiceover incluido'] },
        ].map(p => (
          <div class="brut-reveal" style={p.badge ? 'background:#0063DA; position:relative;' : 'background:#f1f1f1; position:relative;'}>
            {p.badge && <div style="position:absolute; top:0; left:0; right:0; background:#0063DA; padding:6px; text-align:center;">
              <span style="font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:700; text-transform:uppercase; color:#fff;">{p.badge}</span>
            </div>}
            <div style={`padding:${p.badge ? '52px 28px 28px' : '28px'}; height:100%; display:flex; flex-direction:column;`}>
              <h3 style={`font-family:'Barlow Condensed',sans-serif; font-size:24px; font-weight:900; text-transform:uppercase; margin-bottom:8px; color:${p.badge ? '#f1f1f1' : '#111111'};`}>{p.name}</h3>
              <div style={`font-family:'Barlow Condensed',sans-serif; font-size:24px; font-weight:900; margin-bottom:24px; color:${p.badge ? '#f1f1f1' : '#0063DA'};`}>{p.price}</div>
              <ul style="list-style:none; padding:0; margin:0 0 28px; flex-grow:1; display:flex; flex-direction:column; gap:10px;">
                {p.features.map(f => (
                  <li style={`display:flex; gap:8px; font-family:'Barlow',sans-serif; font-size:14px; color:${p.badge ? '#f1f1f1' : '#555555'};`}>
                    <span style={`color:${p.badge ? '#f1f1f1' : '#0063DA'}; flex-shrink:0;`}>✓</span>{f}
                  </li>
                ))}
              </ul>
              <a href="/contacto" class={p.badge ? 'brut-btn-dark brut-btn' : 'brut-btn'} style="justify-content:center;">CONTRATAR →</a>
            </div>
          </div>
        ))}
      </div>

      <!-- Voiceover extra -->
      <div style="margin-top:2px; background:#f1f1f1; border:2px solid #0063DA; padding:48px; display:grid; gap:32px; border-top:0;" class="vo-grid">
        <style>.vo-grid{grid-template-columns:1fr!important} @media(min-width:768px){.vo-grid{grid-template-columns:1fr 1fr!important}}</style>
        <div>
          <span class="brut-tag" style="margin-bottom:16px;">Servicio adicional</span>
          <h3 style="font-family:'Barlow Condensed',sans-serif; font-size:32px; font-weight:900; text-transform:uppercase; color:#111111; margin-bottom:8px;">Narración de Voz (Voiceover)</h3>
          <div style="font-family:'Barlow Condensed',sans-serif; font-size:36px; font-weight:900; color:#0063DA; margin-bottom:16px;">$650 - $1,300</div>
          <p style="font-family:'Barlow',sans-serif; font-size:16px; color:#555555; line-height:1.65; margin-bottom:24px;">
            Dale alma a tus videos con locutores profesionales. Una voz adecuada puede aumentar la confianza en tu marca hasta en un 40%.
          </p>
          <a href="/contacto" class="brut-btn">CONTRATAR →</a>
        </div>
        <div style="border:2px solid #0063DA; overflow:hidden; min-height:200px;">
          <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuBPKu42EU8B_dEIfFjWWQUnk_cu_9F_9uf9zrJXF5trnZ7z9iFlWYnV-trQeUe5SVlG5fVQ6hsCzIPWpzp9TV6FP_35sI9gDGvfzVl0UlPNkwl1HC_kBA3wnnmPhzGDLztMHr34wgyHk2ummY7i24dkRCr3IjkM_amuO0tHNNbQ8LouuEvMEeqJd6YfcSLk9jVbt3rB5wJccUcT-Jp9gvsaAhn8NQpk1It8V8OQMKkRWKY6FEgnbWhMlmbvB22TJYst_w7pUZhEnMMg" alt="Voiceover" style="width:100%; height:100%; object-fit:cover; display:block;" />
        </div>
      </div>

    </div>
  </section>

</Layout>
