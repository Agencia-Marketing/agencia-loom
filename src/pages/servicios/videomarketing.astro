---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Videomarketing | Loom" currentPage="servicios">

  <!-- HERO -->
  <section style="background:#f1f1f1; padding:72px 24px 64px; border-bottom:4px solid #0063DA; border-left:4px solid #0063DA; position:relative; overflow:hidden;">
    <div style="max-width:1280px; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fit, minmax(320px, 1fr)); gap:48px; align-items:center;">

      <div>
        <span class="brut-section-label" style="display:inline-block; background:#0063DA; color:#f1f1f1; padding:4px 12px; border:2px solid #111111; box-shadow:3px 3px 0 #111111; margin-bottom:20px; font-weight:700;">
          [ SERVICIO / 06 ]
        </span>

        <h1 style="font-size:clamp(48px,6vw,84px); line-height:0.92; margin-bottom:20px; text-transform:uppercase; font-weight:900;">
          VIDEO<br/><span style="color:#0063DA;">MARKETING</span>
        </h1>

        <p style="font-family:'Barlow',sans-serif; font-size:18px; color:#555555; line-height:1.6; max-width:540px; margin-bottom:32px;">
          Captura la atención de tu audiencia y multiplica tus conversiones con contenido audiovisual diseñado estratégicamente para vender.
        </p>

        <div style="display:flex; flex-wrap:wrap; gap:16px; align-items:center;">
          <a href="/contacto" class="brut-btn" style="background:#0063DA; color:#f1f1f1; border-color:#0063DA; box-shadow:4px 4px 0 #111111; font-size:13px; padding:16px 28px;">
            COTIZAR MI VIDEO →
          </a>
          <a href="#planes" class="brut-btn" style="font-size:13px; padding:16px 24px;">
            VER FORMATOS
          </a>
        </div>

        <div style="display:flex; gap:20px; margin-top:32px; border-top:2px solid #0063DA; padding-top:20px; flex-wrap:wrap;">
          <span style="font-family:'JetBrains Mono',monospace; font-size:12px; font-weight:700; color:#111111; display:flex; align-items:center; gap:6px;">
            <span style="color:#0063DA;">✓</span> Reels & TikTok
          </span>
          <span style="font-family:'JetBrains Mono',monospace; font-size:12px; font-weight:700; color:#111111; display:flex; align-items:center; gap:6px;">
            <span style="color:#0063DA;">✓</span> Edición Avanzada
          </span>
          <span style="font-family:'JetBrains Mono',monospace; font-size:12px; font-weight:700; color:#111111; display:flex; align-items:center; gap:6px;">
            <span style="color:#0063DA;">✓</span> Guiones Vendedores
          </span>
        </div>
      </div>

      <div style="position:relative;">
        <div style="border:2px solid #0063DA; background:#ffffff; box-shadow:6px 6px 0 #0063DA; padding:20px; position:relative;">
          <img
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuBFUqr1X_pwtHpAKqWNwAPUSlJ5tT3-T5BKTSC_M6ISDLBXNT8Qn2TXvA5C96UgXUfZWfmKJEBv_P18mnzfeewriiEUJeqGpsW2RQD42EgsMFXzHumLN8B9plFTZK-Tn13ozZTVgeuSreTazqm2zALs6LIaFQhsnPZRkUSifKNYZxrxmBZNEyIJgNBmtmtSJ6khRZEWRWUyd1OKtWPnCTrXH_LcAGdxLAZ-F8gpFolWeiiMFWUwJXSRsbAbEK-qCoq8JEvpTtjdOLqs"
            alt="Videomarketing"
            style="width:100%; height:auto; display:block; object-fit:contain; max-height:380px;"
          />
        </div>

        <div style="position:absolute; bottom:-16px; left:-16px; background:#111111; color:#f1f1f1; padding:8px 16px; border:2px solid #0063DA; font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; box-shadow:3px 3px 0 #0063DA;">
          🎬 Edición de Alto Impacto
        </div>
      </div>

    </div>
  </section>

  <!-- FEATURES -->
  <section style="background:#f1f1f1; border-top:4px solid #0063DA;">
    <div style="max-width:1280px; margin:0 auto; display:grid;" class="vm-feat">
      <style>.vm-feat{grid-template-columns:1fr!important} @media(min-width:768px){.vm-feat{grid-template-columns:repeat(3,1fr)!important}}</style>
      {[
        { icon:'favorite',    title:'Mayor Retención',  desc:'Conectamos emocionalmente con tu audiencia.' },
        { icon:'trending_up', title:'Alcance Viral',    desc:'Contenido diseñado para ser compartido en redes.' },
        { icon:'devices',     title:'Multiplataforma',  desc:'YouTube, Reels, TikTok y más.' },
      ].map((f, i) => (
        <div style={`padding:40px 32px; ${i < 2 ? 'border-right:2px solid #0063DA;' : ''}`}>
          <span class="material-symbols-outlined" style="font-size:32px; color:#0063DA; display:block; margin-bottom:16px;">{f.icon}</span>
          <h3 style="font-size:20px; margin-bottom:8px;">{f.title}</h3>
          <p style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#555555; line-height:1.5;">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- FORMATOS Y VOZ EN OFF -->
  <section style="background:#f1f1f1; padding:80px 24px;">
    <div style="max-width:1280px; margin:0 auto; display:grid; grid-template-columns:repeat(auto-fit, minmax(320px, 1fr)); gap:32px; align-items:stretch;">

      <!-- FORMATOS DE VIDEO STANDAR -->
      <div style="border:2px solid #0063DA; background:#ffffff; padding:32px; box-shadow:5px 5px 0 #0063DA; display:flex; flex-direction:column; justify-content:space-between;">
        <div>
          <span class="brut-section-label" style="margin-bottom:8px;">[01] / Formatos Adaptables</span>
          <h2 style="font-size:clamp(26px,3vw,36px); margin-bottom:16px; color:#0063DA;">Formatos de video estándar</h2>
          <p style="font-family:'Barlow',sans-serif; font-size:15px; color:#555555; line-height:1.6; margin-bottom:16px;">Trabajamos con todos los formatos de video disponibles: stories, reels, video para YouTube, videos para redes sociales, videos para campañas, etc.</p>
        </div>
        <div style="border-top:2px solid #0063DA; padding-top:16px;">
          <p style="font-family:'Barlow',sans-serif; font-size:14px; font-weight:700; color:#111111; margin:0;">Consulta con tu ejecutivo de ventas el formato que más se adecue a tu proyecto.</p>
        </div>
      </div>

      <!-- NARRACIÓN DE VOZ EN OFF -->
      <div style="border:2px solid #0063DA; background:#ffffff; padding:32px; box-shadow:5px 5px 0 #0063DA; display:flex; flex-direction:column; justify-content:space-between;">
        <div>
          <span class="brut-section-label" style="margin-bottom:8px;">[02] / Servicio Adicional</span>
          <h2 style="font-size:clamp(26px,3vw,36px); margin-bottom:16px; color:#0063DA;">Narración de voz en off</h2>
          <p style="font-family:'Barlow',sans-serif; font-size:14px; color:#555555; line-height:1.6; margin-bottom:12px;">Te ayudamos a crear el guion y a elegir la voz adecuada para darle vida a tu proyecto.</p>
          <p style="font-family:'Barlow',sans-serif; font-size:13px; color:#111111; margin-bottom:20px;"><strong>NOTA:</strong> La narración de voz no está incluida en el servicio de Video marketing, se contrata por separado.</p>
        </div>

        <!-- PRECIOS VOZ EN OFF -->
        <div style="display:grid; grid-template-columns:repeat(3, 1fr); gap:10px;">
          <div style="border:2px solid #0063DA; background:#0063DA; color:#f1f1f1; padding:12px; text-align:center;">
            <span style="font-size:11px; font-family:'JetBrains Mono',monospace; display:block; margin-bottom:4px;">60 seg</span>
            <strong style="font-family:'Barlow Condensed',sans-serif; font-size:18px;">$1,000 MXN</strong>
          </div>
          <div style="border:2px solid #0063DA; background:#0063DA; color:#f1f1f1; padding:12px; text-align:center;">
            <span style="font-size:11px; font-family:'JetBrains Mono',monospace; display:block; margin-bottom:4px;">30 seg</span>
            <strong style="font-family:'Barlow Condensed',sans-serif; font-size:18px;">$700 MXN</strong>
          </div>
          <div style="border:2px solid #0063DA; background:#0063DA; color:#f1f1f1; padding:12px; text-align:center;">
            <span style="font-size:11px; font-family:'JetBrains Mono',monospace; display:block; margin-bottom:4px;">&lt; 30 seg</span>
            <strong style="font-family:'Barlow Condensed',sans-serif; font-size:18px;">$500 MXN</strong>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- TIPOS DE VIDEO Y PRECIOS -->
  <section id="planes" style="background:#f1f1f1; padding:80px 24px;">
    <div style="max-width:1280px; margin:0 auto;">

      <div style="margin-bottom:40px;">
        <span class="brut-section-label" style="margin-bottom:8px;">[03] / Niveles de Producción</span>
        <h2 style="font-size:clamp(32px,4vw,52px);">Elige el tipo de video <span style="color:#0063DA;">que necesitas</span></h2>
      </div>

      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(300px, 1fr)); gap:24px; align-items:stretch;">

        <!-- VIDEO BÁSICO -->
        <div class="brut-reveal" style="background:#f1f1f1; border:2px solid #0063DA; box-shadow:5px 5px 0 #0063DA; display:flex; flex-direction:column; justify-content:space-between; height:100%;">
          <div>
            <div style="background:#0063DA; color:#f1f1f1; padding:24px; text-align:center;">
              <h3 style="font-size:28px; margin:0; color:#f1f1f1;">Video Básico</h3>
            </div>
            <div style="padding:24px;">
              <p style="font-family:'Barlow',sans-serif; font-size:14px; color:#555555; line-height:1.6; margin-bottom:24px; min-height:48px;">
                Edición de video con transiciones simples y textos 2D, música. Solicita a tu asesor ejemplos.
              </p>
              <div style="display:flex; flex-direction:column; gap:12px; border-top:2px solid #0063DA; padding-top:20px;">
                <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #e0e0e0; padding-bottom:8px;">
                  <span style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#555555;">60 segundos</span>
                  <strong style="font-family:'Barlow Condensed',sans-serif; font-size:22px; color:#0063DA;">$1,785 MXN</strong>
                </div>
                <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #e0e0e0; padding-bottom:8px;">
                  <span style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#555555;">30 segundos</span>
                  <strong style="font-family:'Barlow Condensed',sans-serif; font-size:22px; color:#0063DA;">$1,200 MXN</strong>
                </div>
                <div style="display:flex; justify-content:space-between; align-items:center;">
                  <span style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#555555;">Menos de 30 seg.</span>
                  <strong style="font-family:'Barlow Condensed',sans-serif; font-size:22px; color:#0063DA;">$750 MXN</strong>
                </div>
              </div>
            </div>
          </div>
          <div style="padding:0 24px 24px;">
            <a href="/contacto" class="brut-btn" style="width:100%;">CONTRATAR →</a>
          </div>
        </div>

        <!-- VIDEO INTERMEDIO (RECOMENDADO) -->
        <div class="brut-reveal" style="background:#0063DA; border:2px solid #0063DA; box-shadow:6px 6px 0 #111111; display:flex; flex-direction:column; justify-content:space-between; height:100%; position:relative;">
          <div style="position:absolute; top:0; left:0; right:0; background:#111111; padding:6px; text-align:center;">
            <span style="font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:700; text-transform:uppercase; color:#ffffff;">RECOMENDADO</span>
          </div>
          <div style="padding-top:28px;">
            <div style="background:#0063DA; color:#f1f1f1; padding:20px; text-align:center; border-bottom:2px solid #f1f1f1;">
              <h3 style="font-size:28px; margin:0; color:#f1f1f1;">Video Inter</h3>
            </div>
            <div style="padding:24px;">
              <p style="font-family:'Barlow',sans-serif; font-size:14px; color:#f1f1f1; line-height:1.6; margin-bottom:24px; min-height:48px;">
                Edición de video con transiciones más elaboradas y se anexa el uso de mockups. Solicita a tu asesor ejemplos.
              </p>
              <div style="display:flex; flex-direction:column; gap:12px; border-top:2px solid #f1f1f1; padding-top:20px;">
                <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid rgba(255,255,255,0.2); padding-bottom:8px;">
                  <span style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#f1f1f1;">60 segundos</span>
                  <strong style="font-family:'Barlow Condensed',sans-serif; font-size:22px; color:#ffffff;">$3,570 MXN</strong>
                </div>
                <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid rgba(255,255,255,0.2); padding-bottom:8px;">
                  <span style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#f1f1f1;">30 segundos</span>
                  <strong style="font-family:'Barlow Condensed',sans-serif; font-size:22px; color:#ffffff;">$2,500 MXN</strong>
                </div>
                <div style="display:flex; justify-content:space-between; align-items:center;">
                  <span style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#f1f1f1;">Menos de 30 seg.</span>
                  <strong style="font-family:'Barlow Condensed',sans-serif; font-size:22px; color:#ffffff;">$1,500 MXN</strong>
                </div>
              </div>
            </div>
          </div>
          <div style="padding:0 24px 24px;">
            <a href="/contacto" class="brut-btn" style="width:100%; background:#f1f1f1; color:#0063DA; border-color:#f1f1f1; box-shadow:3px 3px 0 #111111;">CONTRATAR →</a>
          </div>
        </div>

        <!-- VIDEO COMPLETO -->
        <div class="brut-reveal" style="background:#f1f1f1; border:2px solid #0063DA; box-shadow:5px 5px 0 #0063DA; display:flex; flex-direction:column; justify-content:space-between; height:100%;">
          <div>
            <div style="background:#0063DA; color:#f1f1f1; padding:24px; text-align:center;">
              <h3 style="font-size:28px; margin:0; color:#f1f1f1;">Video Completo</h3>
            </div>
            <div style="padding:24px;">
              <p style="font-family:'Barlow',sans-serif; font-size:14px; color:#555555; line-height:1.6; margin-bottom:24px; min-height:48px;">
                Edición de video con transiciones más elaboradas, se anexa el uso de mockups y animaciones. Solicita a tu asesor ejemplos.
              </p>
              <div style="display:flex; flex-direction:column; gap:12px; border-top:2px solid #0063DA; padding-top:20px;">
                <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #e0e0e0; padding-bottom:8px;">
                  <span style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#555555;">60 segundos</span>
                  <strong style="font-family:'Barlow Condensed',sans-serif; font-size:22px; color:#0063DA;">$8,925 MXN</strong>
                </div>
                <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #e0e0e0; padding-bottom:8px;">
                  <span style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#555555;">30 segundos</span>
                  <strong style="font-family:'Barlow Condensed',sans-serif; font-size:22px; color:#0063DA;">$5,200 MXN</strong>
                </div>
                <div style="display:flex; justify-content:space-between; align-items:center;">
                  <span style="font-family:'JetBrains Mono',monospace; font-size:13px; color:#555555;">Menos de 30 seg.</span>
                  <strong style="font-family:'Barlow Condensed',sans-serif; font-size:22px; color:#0063DA;">$2,000 MXN</strong>
                </div>
              </div>
            </div>
          </div>
          <div style="padding:0 24px 24px;">
            <a href="/contacto" class="brut-btn" style="width:100%;">CONTRATAR →</a>
          </div>
        </div>

      </div>

    </div>
  </section>

</Layout>
