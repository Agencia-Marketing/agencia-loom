---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contacto | Loom" currentPage="contacto">

  <!-- HERO -->
  <section style="background:#f1f1f1; padding:100px 24px 80px; border-bottom:2px solid #0063DA;">
    <div style="max-width:1280px; margin:0 auto; display:grid; gap:48px; align-items:center;" class="contact-hero-grid">
      <style>.contact-hero-grid{grid-template-columns:1fr!important} @media(min-width:768px){.contact-hero-grid{grid-template-columns:1fr 1fr!important}}</style>

      <div class="brut-reveal">
        <span class="brut-section-label" style="margin-bottom:20px;">// Contacto</span>
        <h1 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(44px,6vw,80px); font-weight:900; text-transform:uppercase; line-height:0.95; color:#111111; margin-bottom:24px;">
          INICIA TU<br/><span style="color:#0063DA;">PROYECTO</span><br/>CON NOSOTROS
        </h1>
        <p style="font-family:'Barlow',sans-serif; font-size:17px; color:#555555; line-height:1.65; max-width:480px;">
          Escríbenos hoy mismo y descubre cómo nuestras estrategias digitales pueden escalar tus ventas al siguiente nivel.
        </p>
      </div>

      <div class="brut-reveal brut-reveal-delay-2" style="position:relative;">
        <div style="position:absolute; top:-8px; right:-8px; left:8px; bottom:8px; border:2px solid #0063DA;"></div>
        <img
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuAJHuN7GK8OrnqtHB9Hfls1crva_jJrTCIWMzfYcDDp5KmQAJchQmrrMF-g8KVrK3LiRhxz3SgkIWinZ-tdbufDoEhZYK1DBRgXu52RTdeYkZQ7Yuu4DamM_SwYKjW_fDNVstAq9n7vo570eV1o94j6_ejxMBeHbT03qgJ0iw9YaM_zN1fd73RO752OtB7DSvEj4r6LKPeYHp0hsznfi4gPGg4AH59rAIl0p-YQdOQOctj7MeeUa0lIw-DhqAFxc71-oDs1rjxMjtjb"
          alt="Contacto"
          style="width:100%; max-width:500px; border:2px solid #0063DA; display:block; position:relative; z-index:1;"
        />
      </div>

    </div>
  </section>

  <!-- FORM + INFO -->
  <section style="background:#f1f1f1; padding:80px 24px;">
    <div style="max-width:1280px; margin:0 auto; display:grid; gap:64px;" class="contact-form-grid">
      <style>.contact-form-grid{grid-template-columns:1fr!important} @media(min-width:768px){.contact-form-grid{grid-template-columns:1fr 1fr!important}}</style>

      <!-- Info -->
      <div class="brut-reveal">
        <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(28px,3vw,40px); font-weight:900; text-transform:uppercase; color:#111111; margin-bottom:8px;">
          Escríbenos un mensaje
        </h2>
        <p style="font-family:'Barlow',sans-serif; font-size:16px; color:#555555; line-height:1.65; margin-bottom:40px;">
          Un especialista se pondrá en contacto contigo en menos de 24 horas.
        </p>

        <!-- Contact items -->
        <div style="display:flex; flex-direction:column; gap:20px; margin-bottom:40px;">
          <div style="display:flex; align-items:center; gap:16px; padding:20px; border:2px solid #0063DA; background:#f1f1f1; box-shadow:3px 3px 0 #0063DA;">
            <span class="material-symbols-outlined" style="font-size:24px; color:#0063DA;">mail</span>
            <div>
              <div style="font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#555555; margin-bottom:4px;">Atención</div>
              <div style="font-family:'Barlow Condensed',sans-serif; font-size:22px; font-weight:700; text-transform:uppercase;">Lunes a viernes de 08:00 a.m. a 06:00 p.m</div>
            </div>
          </div>
          <div style="display:flex; align-items:center; gap:16px; padding:20px; border:2px solid #0063DA; background:#f1f1f1; box-shadow:3px 3px 0 #0063DA;">
            <span class="material-symbols-outlined" style="font-size:24px; color:#0063DA;">call</span>
            <div>
              <div style="font-family:'JetBrains Mono',monospace; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#555555; margin-bottom:4px;">Teléfono / WhatsApp</div>
              <div style="font-family:'Barlow Condensed',sans-serif; font-size:22px; font-weight:700; text-transform:uppercase;">55 2701 2954</div>
            </div>
          </div>
        </div>

        <!-- Social -->
        <div>
          <div style="font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#555555; margin-bottom:16px;">// Redes Sociales</div>
          <div style="display:flex; gap:12px;">
            <a href="https://www.facebook.com/LOOMmarketingconsultancy/" target="_blank" rel="noopener noreferrer" style="display:inline-flex; align-items:center; justify-content:center; width:44px; height:44px; border:2px solid #0063DA; color:#0063DA; text-decoration:none; background:#f1f1f1;"
              onmouseover="this.style.backgroundColor='#0063DA'; this.style.color='#f1f1f1'; this.style.boxShadow='3px 3px 0 #111111'"
              onmouseout="this.style.backgroundColor='#f1f1f1'; this.style.color='#0063DA'; this.style.boxShadow='none'">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
            <a href="https://www.instagram.com/loommarketing_/" target="_blank" rel="noopener noreferrer" style="display:inline-flex; align-items:center; justify-content:center; width:44px; height:44px; border:2px solid #0063DA; color:#0063DA; text-decoration:none; background:#f1f1f1;"
              onmouseover="this.style.backgroundColor='#0063DA'; this.style.color='#f1f1f1'; this.style.boxShadow='3px 3px 0 #111111'"
              onmouseout="this.style.backgroundColor='#f1f1f1'; this.style.color='#0063DA'; this.style.boxShadow='none'">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Form -->
      <div class="brut-reveal brut-reveal-delay-2" style="background:#f1f1f1; border:2px solid #0063DA; box-shadow:4px 4px 0 #0063DA; padding:48px;">
        <form style="display:flex; flex-direction:column; gap:24px;">

          <div style="display:grid; gap:24px;" class="form-row">
            <style>.form-row{grid-template-columns:1fr!important} @media(min-width:600px){.form-row{grid-template-columns:1fr 1fr!important}}</style>
            <div>
              <label style="display:block; font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#555555; margin-bottom:8px;">Nombre Completo</label>
              <input type="text" placeholder="Ej. Juan Pérez" style="width:100%; padding:14px 16px; background:#ffffff; border:2px solid #0063DA; color:#111111; font-family:'Barlow',sans-serif; font-size:15px; box-sizing:border-box;" />
            </div>
            <div>
              <label style="display:block; font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#555555; margin-bottom:8px;">Email Corporativo</label>
              <input type="email" placeholder="juan@empresa.com" style="width:100%; padding:14px 16px; background:#ffffff; border:2px solid #0063DA; color:#111111; font-family:'Barlow',sans-serif; font-size:15px; box-sizing:border-box;" />
            </div>
          </div>

          <div>
            <label style="display:block; font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#555555; margin-bottom:8px;">Motivo de Consulta</label>
            <select style="width:100%; padding:14px 16px; background:#ffffff; border:2px solid #0063DA; color:#111111; font-family:'Barlow',sans-serif; font-size:15px; appearance:none; cursor:pointer; box-sizing:border-box;">
              <option>Desarrollo Web</option>
              <option>Agentes de IA</option>
              <option>Diseño Gráfico</option>
              <option>Gestión de Redes</option>
              <option>Campañas de Ads</option>
              <option>Otro</option>
            </select>
          </div>

          <div>
            <label style="display:block; font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#555555; margin-bottom:8px;">Mensaje</label>
            <textarea rows="5" placeholder="Cuéntanos sobre tu proyecto..." style="width:100%; padding:14px 16px; background:#ffffff; border:2px solid #0063DA; color:#111111; font-family:'Barlow',sans-serif; font-size:15px; resize:none; box-sizing:border-box;"></textarea>
          </div>

          <button type="submit" class="brut-btn-filled brut-btn" style="width:100%; justify-content:center; font-size:13px;">
            SOLICITAR ASESORÍA →
          </button>
        </form>
      </div>

    </div>
  </section>

  <!-- MAP -->
  <section style="width:100%; height:400px; position:relative; background:#f1f1f1; border-bottom:2px solid #0063DA; overflow:hidden;">
    <img
      src="https://lh3.googleusercontent.com/aida-public/AB6AXuB6nVHVZWEmKfyoBWn-FocTAn2-7tBv-I3y8V1qDJZHchTN08ELSff4YuFB4i8YkCFv8DReKKJyNjxpH-Ke-BqpShVLWI7kk7e0Kldz-EdF70UKnnAAwyI2ZAPyFZ_Sa05mBcJjfDw8nWX4KhJwZT8d22qRDMFzvQmwQVuT-knP_aAkD_r8LNNiTOzwGvtT_ldcjCMFmrD-PTGWZy-BsfujARWgDornIb7CXgvISIfPsMmZ2xtQYpBlwjxyqpxvP63bOMdb-dKTOdZP"
      alt="Mapa"
      style="width:100%; height:100%; object-fit:cover; filter:grayscale(100%) contrast(1.1); display:block; opacity:0.8;"
    />
    <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center;">
      <div style="background:#0063DA; color:#f1f1f1; padding:16px 28px; border:2px solid #0063DA; box-shadow:4px 4px 0 #111111; display:flex; align-items:center; gap:10px;">
        <span class="material-symbols-outlined" style="font-size:20px;">location_on</span>
        <span style="font-family:'Barlow Condensed',sans-serif; font-size:20px; font-weight:900; text-transform:uppercase; letter-spacing:0.02em;">Atención en México y Estados Unidos</span>
      </div>
    </div>
  </section>

</Layout>
