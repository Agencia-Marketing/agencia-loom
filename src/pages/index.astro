---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Loom | Agencia Digital" currentPage="inicio">

  <!-- ═══════════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════ -->
  <section class="brut-grid-bg" style="border-bottom:2px solid #0063DA; padding:120px 24px 80px;">
    <div style="max-width:1280px; margin:0 auto; display:grid; grid-template-columns:1fr; gap:48px; align-items:center;">
      <div class="md:grid" style="display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center;">

        <!-- Text -->
        <div class="brut-reveal">
          <span class="brut-section-label" style="margin-bottom:20px;">// Agencia Digital</span>
          <h1 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(52px,8vw,96px); font-weight:900; text-transform:uppercase; line-height:0.95; letter-spacing:-0.02em; color:#111111; margin-bottom:28px;">
            Bienvenido a Loom<br/>
            <span style="color:#0063DA;">Tu Aliado para lograr</span><br/>
            el Éxito para tu negocio!
          </h1>
          <p style="font-family:'Barlow',sans-serif; font-size:18px; color:#555555; line-height:1.65; max-width:480px; margin-bottom:36px;">
            En Loom con nuestros servicios de consultoría en marketing y publicidad nos especializamos en ayudar a negocios en México y Estados Unidos a incrementar sus ventas y clientes satisfechos mediante el marketing y la publicidad estratégica.
          </p>
          <div style="display:flex; gap:16px; flex-wrap:wrap;">
            <button onclick="document.getElementById('servicios').scrollIntoView({behavior:'smooth'})" class="brut-btn">
              Ver Servicios →
            </button>
            <a href="/contacto" class="brut-btn">
              Hablar con un experto
            </a>
          </div>
        </div>

        <!-- Image -->
        <div class="brut-reveal brut-reveal-delay-2" style="position:relative;">
          <div style="position:absolute; top:-12px; left:-12px; right:12px; bottom:12px; border:2px solid #0063DA; z-index:0; pointer-events:none;"></div>
          <img
            src="/img/digital-marketing.png"
            alt="Agencia Digital"
            style="width:100%; position:relative; z-index:1; border:2px solid #0063DA; display:block;"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SERVICIOS GRID
  ════════════════════════════════════════════════ -->
  <section id="servicios" style="background:#f1f1f1; padding:80px 24px;">
    <div style="max-width:1280px; margin:0 auto;">

      <!-- Header -->
      <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:24px; padding-bottom:24px; border-bottom:2px solid #0063DA;">
        <div>
          <span class="brut-section-label">[01] / Servicios</span>
          <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(36px,5vw,56px); font-weight:900; text-transform:uppercase; color:#111111; margin-top:8px;">
            Lo Que<br/><span style="color:#0063DA;">hacemos</span>
          </h2>
        </div>
      </div>
      <p style="font-family:'Barlow',sans-serif; font-size:16px; color:#555555; line-height:1.65; margin-bottom:36px;">
        Desde estrategias de contenido y publicidad en línea hasta análisis de datos e investigación, entendimiento al consumidor y desarrollo web, ofrecemos una amplia gama de servicios de marketing digital.
      </p>

      <!-- Grid 3×3 -->
      <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(300px, 1fr)); gap:16px; background:#f1f1f1;">

        {[
          { icon: 'code',        title: 'Desarrollo Web',      slug: 'desarrollo-web',         desc: 'Plataformas a medida rápidas, adaptables y optimizadas para convertir visitas en clientes reales.' },
          { icon: 'smart_toy',   title: 'Agentes de IA',        slug: 'agentes-ia',             desc: 'Agentes inteligentes para automatizar tus procesos de atención y aumentar tus ventas 24/7.' },
          { icon: 'palette',     title: 'Diseño Gráfico',       slug: 'diseno-grafico',         desc: 'Potenciamos tu marca con creaciones visuales atractivas y de nivel premium.' },
          { icon: 'diversity_3', title: 'Gestión de Redes',     slug: 'redes-sociales',         desc: 'Incrementa la interacción y la notoriedad de tu marca con gestión experta.' },
          { icon: 'ads_click',   title: 'Campañas de Ads',      slug: 'campanas-publicitarias', desc: 'Capta clientes calificados con campañas publicitarias optimizadas de alto rendimiento.' },
          { icon: 'movie',       title: 'Videomarketing',       slug: 'videomarketing',         desc: 'Piezas audiovisuales dinámicas que conectan emocionalmente con tu audiencia.' },
          { icon: 'filter_alt',  title: 'Embudos de Venta',     slug: 'embudos-venta',          desc: 'Sistemas automatizados para llevar a tus prospectos hasta la conversión final.' },
          { icon: 'campaign',    title: 'Creadores UGC',        slug: 'creadores-ugc',          desc: 'Conectamos tu marca con creadores auténticos para campañas que generan confianza.' },
          { icon: 'history_edu', title: 'Creación de Contenido',slug: 'creacion-contenido',     desc: 'Contenidos atractivos para educir, captar interés y posicionar tu marca.' },
        ].map((s, i) => (
          <div class="brut-card brut-reveal" style="padding:32px; display:flex; flex-direction:column; height:100%;">
            <!-- Card header -->
            <div style="display:flex; align-items:center; justify-content:space-between; padding-bottom:16px; border-bottom:2px solid #2A2A2A; margin-bottom:20px;">
              <span class="material-symbols-outlined" style="font-size:28px; color:#0063DA;">{s.icon}</span>
              <span style="font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; color:#0063DA;">/{String(i+1).padStart(2,'0')}</span>
            </div>
            <h3 style="font-family:'Barlow Condensed',sans-serif; font-size:22px; font-weight:700; text-transform:uppercase; color:#111111; margin-bottom:12px;">{s.title}</h3>
            <p style="font-family:'Barlow',sans-serif; font-size:15px; color:#555555; line-height:1.6; flex-grow:1; margin-bottom:24px;">{s.desc}</p>
            <a href={`/servicios/${s.slug}`} class="brut-btn" style="align-self:flex-start; font-size:12px; padding:10px 20px;">
              + Info →
            </a>
          </div>
        ))}

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       POR QUÉ ELEGIRNOS
  ════════════════════════════════════════════════ -->
  <section style="background:#f1f1f1; padding:80px 24px;">
    <div style="max-width:1280px; margin:0 auto;">
      <div style="border-bottom:4px solid #0063DA; padding-bottom:32px; margin-bottom:0;">
        <span style="font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; color:#0063DA;">[02] / Por qué elegirnos</span>
        <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(36px,5vw,56px); font-weight:900; text-transform:uppercase; color:#111111; margin-top:8px;">
          Razones para trabajar con nosotros
        </h2>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; border-left:2px solid #0063DA;">
        {[
          { t:'Amplia Trayectoria',             d:'Años de experiencia liderando campañas de marketing exitosas en el sector digital.' },
          { t:'Equipo de Especialistas',         d:'Profesionales altamente cualificados en cada área del marketing digital.' },
          { t:'Creatividad e Innovación',        d:'Ideas bien ejecutadas para diferenciar tu marca en un entorno saturado.' },
          { t:'Enfoque en Resultados',           d:'Datos reales para optimizar cada fase de tu estrategia digital.' },
        ].map((item, i) => (
          <div style={`padding:48px; border-right:2px solid #0063DA; border-bottom:${i < 2 ? '2px solid #0063DA' : 'none'};`}>
            <h3 style="font-family:'Barlow Condensed',sans-serif; font-size:28px; font-weight:900; text-transform:uppercase; color:#0063DA; margin-bottom:12px;">{item.t}</h3>
            <p style="font-family:'Barlow',sans-serif; font-size:16px; color:#555555; line-height:1.6;">{item.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       CTA FINAL
  ════════════════════════════════════════════════ -->
  <section style="background:#f1f1f1; padding:80px 24px;">
    <div style="max-width:1280px; margin:0 auto;">
      <div style="border:2px solid #0063DA; display:grid; grid-template-columns:1fr; overflow:hidden;" class="md-grid-2">
        <style>.md-grid-2{grid-template-columns:1fr!important} @media(min-width:768px){.md-grid-2{grid-template-columns:1fr 1fr!important}}</style>

        <!-- Text -->
        <div style="padding:64px 48px;" class="brut-reveal">
          <span class="brut-section-label" style="margin-bottom:16px;">[03] / Empieza hoy</span>
          <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(36px,5vw,52px); font-weight:900; text-transform:uppercase; color:#111111; margin-bottom:20px; line-height:1.0;">
            Empieza Tu<br/><span style="color:#0063DA;">Viaje Digital</span>
          </h2>
          <p style="font-family:'Barlow',sans-serif; font-size:16px; color:#555555; line-height:1.65; margin-bottom:36px;">
            Sin importar el tamaño de tu negocio, en Loom te ofrecemos la orientación y las soluciones que necesitas para capitalizar el mundo digital. Tu viaje digital comienza ahora. Explora nuestros servicios, ponte en contacto con nosotros y descubre cómo Loom puede ser tu aliado en este emocionante mundo en línea.
          </p>
          <a href="/contacto" class="brut-btn">
            Empieza ahora →
          </a>
        </div>

        <!-- Image -->
        <div style="border-left:2px solid #0063DA; min-height:300px; overflow:hidden;">
          <img
            src="/img/empieza-hoy.png"
            alt="Especialista"
            style="width:100%; height:100%; object-fit:cover; display:block;"
          />
        </div>

      </div>
    </div>
  </section>

</Layout>
