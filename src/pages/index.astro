---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Plantilla 2 | Agencia Digital" currentPage="inicio">

  <!-- ═══════════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════ -->
  <section class="brut-grid-bg" style="border-bottom:2px solid #3D3D3D; padding:120px 24px 80px;">
    <div style="max-width:1280px; margin:0 auto; display:grid; grid-template-columns:1fr; gap:48px; align-items:center;">
      <div class="md:grid" style="display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center;">

        <!-- Text -->
        <div class="brut-reveal">
          <span class="brut-section-label" style="margin-bottom:20px;">// Agencia Digital</span>
          <h1 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(52px,8vw,96px); font-weight:900; text-transform:uppercase; line-height:0.95; letter-spacing:-0.02em; color:#F0F0F0; margin-bottom:28px;">
            MAXIMIZA<br/>
            <span style="color:#AAFF00;">EL IMPACTO</span><br/>
            DE TU MARCA
          </h1>
          <p style="font-family:'Barlow',sans-serif; font-size:18px; color:#888; line-height:1.65; max-width:480px; margin-bottom:36px;">
            Eleva tu presencia digital con estrategias de alto rendimiento diseñadas para el éxito sostenido de tu empresa.
          </p>
          <div style="display:flex; gap:16px; flex-wrap:wrap;">
            <button onclick="document.getElementById('servicios').scrollIntoView({behavior:'smooth'})" class="brut-btn">
              Ver Servicios →
            </button>
            <a href="/contacto" class="brut-btn-secondary brut-btn">
              Hablar con un experto
            </a>
          </div>
        </div>

        <!-- Image -->
        <div class="brut-reveal brut-reveal-delay-2" style="position:relative;">
          <div style="position:absolute; top:-12px; left:-12px; right:12px; bottom:12px; border:2px solid #AAFF00; z-index:0; pointer-events:none;"></div>
          <img
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuCLnSXflK2O240IsFhJYQzcgOWK_Zwx4hZdbZ4Q_xkoT3BYT3K73sSBWEMvrj6lXjuZhiOpT_3Nh4ZawOCQeJzkmwo8WB9eMbdyDwXrgv63JLYwkx-dCv9Z6dSuu3O1zTUUZPKGxJEoleqwktDtqUUV9UQMTQSQr-G2QTALFux1cKHWik2cPYhadu13u2beZ0gUp5p7EvRqLAJN20nkRqTJoaV1F_p-sZLi8ntAz-zMUEMk0BZCeGOsLTLF_NH3Pr-JOqp3UvaETxWv"
            alt="Agencia Digital"
            style="width:100%; position:relative; z-index:1; border:2px solid #3D3D3D; display:block;"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SERVICIOS GRID
  ════════════════════════════════════════════════ -->
  <section id="servicios" style="background:#111111; padding:80px 24px;">
    <div style="max-width:1280px; margin:0 auto;">

      <!-- Header -->
      <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:48px; padding-bottom:24px; border-bottom:2px solid #3D3D3D;">
        <div>
          <span class="brut-section-label">[01] / Servicios</span>
          <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(36px,5vw,56px); font-weight:900; text-transform:uppercase; color:#F0F0F0; margin-top:8px;">
            Soluciones para tu<br/><span style="color:#AAFF00;">crecimiento digital</span>
          </h2>
        </div>
        <span style="font-family:'JetBrains Mono',monospace; font-size:64px; font-weight:700; color:#2A2A2A; line-height:1; display:none; md:display:block;">09</span>
      </div>

      <!-- Grid 3×3 -->
      <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(300px, 1fr)); gap:2px; background:#2A2A2A; border:2px solid #2A2A2A;">

        {[
          { icon: 'code',        title: 'Desarrollo Web',      slug: 'desarrollo-web',         desc: 'Plataformas a medida rápidas, adaptables y optimizadas para convertir visitas en clientes reales.' },
          { icon: 'smart_toy',   title: 'Agentes de IA',        slug: 'agentes-ia',             desc: 'Agentes inteligentes para automatizar tus procesos de atención y aumentar tus ventas 24/7.' },
          { icon: 'palette',     title: 'Diseño Gráfico',       slug: 'diseno-grafico',         desc: 'Potenciamos tu marca con creaciones visuales atractivas y de nivel premium.' },
          { icon: 'diversity_3', title: 'Gestión de Redes',     slug: 'redes-sociales',         desc: 'Incrementa la interacción y la notoriedad de tu marca con gestión experta.' },
          { icon: 'ads_click',   title: 'Campañas de Ads',      slug: 'campanas-publicitarias', desc: 'Capta clientes calificados con campañas publicitarias optimizadas de alto rendimiento.' },
          { icon: 'movie',       title: 'Videomarketing',       slug: 'videomarketing',         desc: 'Piezas audiovisuales dinámicas que conectan emocionalmente con tu audiencia.' },
          { icon: 'filter_alt',  title: 'Embudos de Venta',     slug: 'embudos-venta',          desc: 'Sistemas automatizados para llevar a tus prospectos hasta la conversión final.' },
          { icon: 'campaign',    title: 'Creadores UGC',        slug: 'creadores-ugc',          desc: 'Conectamos tu marca con creadores auténticos para campañas que generan confianza.' },
          { icon: 'history_edu', title: 'Creación de Contenido',slug: 'creacion-contenido',     desc: 'Contenidos atractivos para educir, captar interés y posicionar tu marca.' },
        ].map((s, i) => (
          <div class="brut-reveal" style={`background:#111111; padding:32px; display:flex; flex-direction:column; height:100%; transition:background 150ms ease-out;`}
            onmouseover="this.style.background='#191919'"
            onmouseout="this.style.background='#111111'">
            <!-- Card header -->
            <div style="display:flex; align-items:center; justify-content:space-between; padding-bottom:16px; border-bottom:2px solid #2A2A2A; margin-bottom:20px;">
              <span class="material-symbols-outlined" style="font-size:28px; color:#AAFF00;">{s.icon}</span>
              <span style="font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; color:#3D3D3D;">/{String(i+1).padStart(2,'0')}</span>
            </div>
            <h3 style="font-family:'Barlow Condensed',sans-serif; font-size:22px; font-weight:700; text-transform:uppercase; color:#F0F0F0; margin-bottom:12px;">{s.title}</h3>
            <p style="font-family:'Barlow',sans-serif; font-size:15px; color:#888; line-height:1.6; flex-grow:1; margin-bottom:24px;">{s.desc}</p>
            <a href={`/servicios/${s.slug}`} class="brut-btn" style="align-self:flex-start; font-size:12px; padding:10px 20px;">
              + Info →
            </a>
          </div>
        ))}

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       POR QUÉ ELEGIRNOS
  ════════════════════════════════════════════════ -->
  <section style="background:#AAFF00; padding:80px 24px;">
    <div style="max-width:1280px; margin:0 auto;">
      <div style="border-bottom:4px solid #0A0A0A; padding-bottom:32px; margin-bottom:0;">
        <span style="font-family:'JetBrains Mono',monospace; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; color:#1A2600;">[02] / Por qué elegirnos</span>
        <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(36px,5vw,56px); font-weight:900; text-transform:uppercase; color:#0A0A0A; margin-top:8px;">
          Razones para trabajar con nosotros
        </h2>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; border-left:2px solid #0A0A0A;">
        {[
          { t:'Amplia Trayectoria',             d:'Años de experiencia liderando campañas de marketing exitosas en el sector digital.' },
          { t:'Equipo de Especialistas',         d:'Profesionales altamente cualificados en cada área del marketing digital.' },
          { t:'Creatividad e Innovación',        d:'Ideas bien ejecutadas como pilares para diferenciar tu marca en un entorno saturado.' },
          { t:'Enfoque en Resultados',           d:'Usamos datos reales para optimizar cada fase de tu estrategia digital.' },
        ].map((item, i) => (
          <div style={`padding:48px; border-right:2px solid #0A0A0A; border-bottom:${i < 2 ? '2px solid #0A0A0A' : 'none'};`}>
            <h3 style="font-family:'Barlow Condensed',sans-serif; font-size:28px; font-weight:900; text-transform:uppercase; color:#0A0A0A; margin-bottom:12px;">{item.t}</h3>
            <p style="font-family:'Barlow',sans-serif; font-size:16px; color:#1A2600; line-height:1.6;">{item.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       CTA FINAL
  ════════════════════════════════════════════════ -->
  <section style="background:#0A0A0A; padding:80px 24px;">
    <div style="max-width:1280px; margin:0 auto;">
      <div style="border:2px solid #3D3D3D; display:grid; grid-template-columns:1fr; overflow:hidden;" class="md-grid-2">
        <style>.md-grid-2{grid-template-columns:1fr!important} @media(min-width:768px){.md-grid-2{grid-template-columns:1fr 1fr!important}}</style>

        <!-- Text -->
        <div style="padding:64px 48px;" class="brut-reveal">
          <span class="brut-section-label" style="margin-bottom:16px;">[03] / Empieza hoy</span>
          <h2 style="font-family:'Barlow Condensed',sans-serif; font-size:clamp(36px,5vw,52px); font-weight:900; text-transform:uppercase; color:#F0F0F0; margin-bottom:20px; line-height:1.0;">
            Por qué Plantilla 2 es tu<br/><span style="color:#AAFF00;">mejor opción</span>
          </h2>
          <p style="font-family:'Barlow',sans-serif; font-size:16px; color:#888; line-height:1.65; margin-bottom:36px;">
            Nuestro enfoque diferente, basado en la personalización y la innovación constante, nos permite ofrecer soluciones que realmente impactan en el crecimiento de tu negocio.
          </p>
          <a href="/contacto" class="brut-btn">
            Empieza ahora →
          </a>
        </div>

        <!-- Image -->
        <div style="border-left:2px solid #3D3D3D; min-height:300px; overflow:hidden;">
          <img
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuBtzci1QtmfbUubFYJE_UBdNN2kzW2bYIBjN9nyBvQ7tYyRjqvSMc4p6b0lGlCC2UO-CceR-OUDeYhZ5rfjjVyQ0muUvBm5qjS6ZBn3Tv1nHWDonfspONEYlW7AdcmDvcm_Nc2ac3M-0cd4UNpUfTNXCEXXI-jLWclXiv8Tv-xgMT2f7LtqDSwcPbSjSPhQHjAkGLbJTgqy2K21Dvls0EIdd5u1gv9DZdCoQyV2roKW-Q_ZcmIkfIBwljZ9GzVXn0lJaZQA2OIP6bx"
            alt="Especialista"
            style="width:100%; height:100%; object-fit:cover; display:block;"
          />
        </div>

      </div>
    </div>
  </section>

</Layout>
